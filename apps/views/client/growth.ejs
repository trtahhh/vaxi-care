<%- include('../partials/client-page-header', {
    title: 'Theo dõi tăng trưởng',
    subtitle: 'Theo dõi sự phát triển thể chất của bé theo chuẩn WHO.',
    backHref: '/client/dashboard'
}) %>

<div class="space-y-8 animate-fade-in">

  <%# Status Banner %>
  <div class="v-card !p-10 border-2 border-primary/30">
    <span class="v-badge bg-primary text-white border-transparent uppercase mb-4 shadow-sm shadow-primary/20">TÌNH TRẠNG HIỆN TẠI</span>
    <div class="flex items-center gap-4 mb-4">
      <h2 class="text-4xl font-display font-black uppercase tracking-tight text-on-surface leading-none">PHÁT TRIỂN TỐT</h2>
      <div class="w-4 h-4 rounded-full bg-primary animate-pulse shadow-[0_0_15px_rgba(59,130,246,0.5)]"></div>
    </div>
    <p class="text-on-surface-variant font-medium text-sm leading-relaxed opacity-80 max-w-lg">
      Chỉ số cân nặng và chiều cao của bé hiện tại nằm ở mức trung bình — một tín hiệu sức khỏe tốt.
    </p>
    <button class="v-btn v-btn-primary !mt-8 !px-6 !py-3 !text-[10px] uppercase tracking-widest gap-2 shadow-lg shadow-primary/20">
      <span class="material-symbols-outlined text-sm">edit_square</span>
      CẬP NHẬT CHỈ SỐ
    </button>
  </div>

  <%# Metrics Grid: Weight + Height cards %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="v-card !p-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
          <span class="material-symbols-outlined text-2xl">scale</span>
        </div>
        <p class="text-[10px] font-black uppercase text-on-surface-variant tracking-widest">CÂN NẶNG HIỆN TẠI</p>
      </div>
      <p class="text-5xl font-display font-black text-on-surface tracking-tight leading-none mt-2">-- <span class="text-xl font-bold text-on-surface-variant uppercase ml-1">KG</span></p>
      <div class="mt-6 w-full h-2 bg-background rounded-full border border-outline overflow-hidden">
        <div class="h-full bg-primary rounded-full" style="width: 40%"></div>
      </div>
      <p class="text-[9px] font-medium text-on-surface-variant mt-2 uppercase tracking-tight">So với chuẩn WHO: 40th percentile</p>
    </div>

    <div class="v-card !p-8">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-10 h-10 bg-secondary/10 rounded-xl flex items-center justify-center text-secondary">
          <span class="material-symbols-outlined text-2xl">straighten</span>
        </div>
        <p class="text-[10px] font-black uppercase text-on-surface-variant tracking-widest">CHIỀU CAO HIỆN TẠI</p>
      </div>
      <p class="text-5xl font-display font-black text-on-surface tracking-tight leading-none mt-2">-- <span class="text-xl font-bold text-on-surface-variant uppercase ml-1">CM</span></p>
      <div class="mt-6 w-full h-2 bg-background rounded-full border border-outline overflow-hidden">
        <div class="h-full bg-secondary rounded-full" style="width: 55%"></div>
      </div>
      <p class="text-[9px] font-medium text-on-surface-variant mt-2 uppercase tracking-tight">So với chuẩn WHO: 55th percentile</p>
    </div>
  </div>

  <%# Doctor Tip Card %>
  <div class="v-card !p-6 !bg-primary/5 !border-primary/20 flex items-start gap-5">
    <div class="w-12 h-12 bg-primary text-white rounded-xl flex items-center justify-center shrink-0 shadow-lg shadow-primary/20">
      <span class="material-symbols-outlined text-2xl">medical_services</span>
    </div>
    <div>
      <h4 class="v-title text-[14px] text-primary mb-2 uppercase tracking-tight">Cố vấn chuyên môn</h4>
      <p class="text-on-surface-variant text-sm font-medium leading-relaxed">
        Hãy bổ sung kẽm và Vitamin D3 để củng cố hệ xương cũng như sức đề kháng tự nhiên cho bé nhé.
      </p>
    </div>
  </div>

</div>
