<!-- =====================
  Vaccination Roadmap
  Data: roadmap, child, error
===================== -->

<% const r = roadmap; %>
<% const c = r.child; %>

<%- include('../partials/client-page-header', {
    title: 'Lộ trình tiêm chủng',
    subtitle: 'Phác đồ theo tuổi cho ' + (c ? c.name : 'bé'),
    backHref: '/client/children/' + (c ? c.id : '') + '/detail',
    backIcon: 'arrow_back'
}) %>

<div class="space-y-6 animate-fade-in">

  <%# ============ HERO CARD ============ %>
  <div class="v-card !p-0 overflow-hidden !bg-gradient-to-br !from-primary !to-[#2B6CB0] !border-none shadow-xl">
    <div class="!p-8">
      <div class="flex flex-col sm:flex-row sm:items-center gap-6">
        <%# Avatar %>
        <div class="w-16 h-16 rounded-2xl bg-white/20 flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-4xl text-white">child_care</span>
        </div>
        <%# Info %>
        <div class="flex-1">
          <p class="text-white/60 text-[10px] font-black uppercase tracking-widest mb-1">Hồ sơ</p>
          <h2 class="text-3xl font-display font-black text-white tracking-tight leading-none"><%= c.name %></h2>
          <div class="flex flex-wrap items-center gap-3 mt-2">
            <span class="text-white/80 text-sm font-bold"><%= c.ageLabel %></span>
            <span class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
            <span class="text-white/80 text-sm font-bold">Đã tiêm <%= r.stats.completedCount %>/<%= r.stats.totalDueCount %> mũi</span>
          </div>
        </div>
        <%# Progress circle %>
        <div class="relative shrink-0">
          <svg width="80" height="80" viewBox="0 0 80 80">
            <circle cx="40" cy="40" r="34" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="6"/>
            <circle cx="40" cy="40" r="34" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"
              stroke-dasharray="<%= (r.stats.progressPercent / 100) * 213.63 %> 213.63"
              transform="rotate(-90 40 40)" />
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-xl font-black text-white leading-none"><%= r.stats.progressPercent %>%</span>
            <span class="text-[8px] font-bold text-white/60 uppercase tracking-widest">tiến độ</span>
          </div>
        </div>
      </div>

      <%# Progress bar %>
      <div class="mt-6">
        <div class="flex justify-between mb-1.5">
          <span class="text-[10px] font-black text-white/60 uppercase tracking-widest">Tiến độ tiêm chủng</span>
          <span class="text-[10px] font-black text-white/80"><%= r.stats.completedCount %> / <%= r.stats.totalDueCount %> mũi</span>
        </div>
        <div class="w-full bg-white/20 rounded-full h-3 overflow-hidden">
          <div class="h-full bg-white rounded-full transition-all duration-700" style="width: <%= r.stats.progressPercent %>%"></div>
        </div>
      </div>
    </div>

    <%# Status bar %>
    <div class="grid grid-cols-3 divide-x divide-white/20">
      <div class="!px-6 !py-4 text-center">
        <p class="text-2xl font-black text-white"><%= r.stats.overdueCount %></p>
        <p class="text-[9px] font-bold text-white/60 uppercase tracking-widest mt-0.5">Quá hạn</p>
      </div>
      <div class="!px-6 !py-4 text-center">
        <p class="text-2xl font-black text-yellow-300"><%= r.stats.dueNowCount %></p>
        <p class="text-[9px] font-bold text-yellow-200/80 uppercase tracking-widest mt-0.5">Cần tiêm ngay</p>
      </div>
      <div class="!px-6 !py-4 text-center">
        <p class="text-2xl font-black text-white/60"><%= r.stats.upcomingSoonCount %></p>
        <p class="text-[9px] font-bold text-white/60 uppercase tracking-widest mt-0.5">Sắp tới</p>
      </div>
    </div>
  </div>

  <%# ============ NEXT ACTIONS ============ %>
  <% const actions = r.nextActions || []; %>
  <% if (actions.length > 0) { %>
  <div class="v-card !p-6">
    <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface mb-5 flex items-center gap-2">
      <span class="material-symbols-outlined text-error text-2xl">priority_high</span>
      Hành động cần làm ngay
    </h3>
    <div class="space-y-3">
      <% actions.forEach(a => { %>
        <% const badge = a.type === 'overdue' ? 'bg-error/10 text-error border-error/20' : a.type === 'due_now' ? 'bg-warning/10 text-warning border-warning/20' : 'bg-primary/10 text-primary border-primary/20'; %>
        <% const badgeIcon = a.type === 'overdue' ? 'warning' : a.type === 'due_now' ? 'schedule' : 'upcoming'; %>
        <div class="flex items-start gap-4 p-4 bg-background rounded-xl border border-outline hover:border-primary/30 transition-colors">
          <div class="w-10 h-10 rounded-xl bg-<%= a.type === 'overdue' ? 'error' : a.type === 'due_now' ? 'warning' : 'primary' %>/10 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-<%= a.type === 'overdue' ? 'error' : a.type === 'due_now' ? 'warning' : 'primary' %> text-xl">priority_high</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <div>
                <p class="font-black text-on-surface"><%= a.vaccine.name %></p>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mt-0.5">
                  Mốc <%= a.milestoneLabel %> •
                  <%= new Date(a.milestoneDate).toLocaleDateString('vi-VN') %>
                </p>
              </div>
              <span class="v-badge <%= badge %> shrink-0">
                <%= a.type === 'overdue' ? 'Quá hạn' : a.type === 'due_now' ? 'Cần tiêm' : 'Sắp tới' %>
              </span>
            </div>
          </div>
          <% if (a.vaccine.stock > 0) { %>
          <a href="/appointments/book?childId=<%= c.id %>&vaccineId=<%= a.vaccine.id %>"
             class="v-btn v-btn-primary v-btn-sm shrink-0 no-underline">
            <span class="material-symbols-outlined v-icon-14">calendar_add_on</span>
            Đặt lịch
          </a>
          <% } else { %>
          <span class="v-badge bg-error/10 text-error border border-error/20 shrink-0">Hết hàng</span>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <%# ============ ROADMAP TIMELINE ============ %>
  <div class="v-card !p-0 overflow-hidden">
    <div class="!px-8 !py-6 border-b border-outline bg-background/50 flex items-center justify-between">
      <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-2xl">timeline</span>
        Lộ trình tiêm chủng theo phác đồ
      </h3>
      <span class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest">
        <%= r.milestones.length %> mốc
      </span>
    </div>

    <%# Legend %>
    <div class="!px-8 !py-3 border-b border-outline/50 bg-background/30 flex flex-wrap gap-4">
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-secondary"></span><span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Đã hoàn thành</span></div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-primary"></span><span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Sắp tới</span></div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-warning"></span><span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Cần tiêm</span></div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-error"></span><span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Quá hạn</span></div>
      <div class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-outline"></span><span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">Chưa đến lịch</span></div>
    </div>

    <%# Timeline %>
    <div class="divide-y divide-outline">
      <% r.milestones.forEach((ms, idx) => { %>
        <%
          const statusColor = ms.status === 'completed' ? 'border-secondary bg-secondary/5'
            : ms.status === 'overdue' ? 'border-error bg-error/5'
            : ms.status === 'due_now' ? 'border-warning bg-warning/5'
            : ms.status === 'upcoming_soon' ? 'border-primary/40 bg-primary/5'
            : 'border-outline bg-background';
          const dotColor = ms.status === 'completed' ? 'bg-secondary text-white'
            : ms.status === 'overdue' ? 'bg-error text-white animate-pulse'
            : ms.status === 'due_now' ? 'bg-warning text-white'
            : ms.status === 'upcoming_soon' ? 'bg-primary text-white'
            : 'bg-outline text-on-surface-variant';
          const dotIcon = ms.status === 'completed' ? 'check_circle'
            : ms.status === 'overdue' ? 'warning'
            : ms.status === 'due_now' ? 'schedule'
            : ms.status === 'upcoming_soon' ? 'upcoming'
            : 'event';
          const statusBadge = ms.status === 'completed' ? 'bg-secondary/10 text-secondary border-secondary/20'
            : ms.status === 'overdue' ? 'bg-error/10 text-error border-error/20'
            : ms.status === 'due_now' ? 'bg-warning/10 text-warning border-warning/20'
            : ms.status === 'upcoming_soon' ? 'bg-primary/10 text-primary border-primary/20'
            : 'bg-outline/50 text-on-surface-variant border-outline/20';
          const statusLabel = ms.status === 'completed' ? 'Đã hoàn thành'
            : ms.status === 'overdue' ? 'Quá hạn'
            : ms.status === 'due_now' ? 'Cần tiêm ngay'
            : ms.status === 'upcoming_soon' ? 'Sắp tới'
            : 'Chưa đến lịch';
          const milestoneAge = ms.label;
        %>
        <div class="!px-8 !py-5 <%= statusColor %> transition-colors">
          <%# Milestone header %>
          <div class="flex items-start gap-4 mb-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 <%= dotColor %>">
              <span class="material-symbols-outlined text-xl"><%= dotIcon %></span>
            </div>
            <div class="flex-1">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <h4 class="text-xl font-display font-black text-on-surface tracking-tight leading-none">
                    <%= milestoneAge %>
                  </h4>
                  <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mt-0.5">
                    <%= new Date(ms.date).toLocaleDateString('vi-VN', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %>
                  </p>
                </div>
                <span class="v-badge <%= statusBadge %> shrink-0">
                  <span class="material-symbols-outlined text-[12px]"><%= dotIcon %></span>
                  <%= statusLabel %>
                </span>
              </div>
              <% if (ms.overdue && ms.vaccines.filter(v => !v.done).length > 0) { %>
              <div class="mt-2 px-3 py-2 bg-error/10 rounded-lg border border-error/20 flex items-center gap-2">
                <span class="material-symbols-outlined text-error text-sm shrink-0">warning</span>
                <p class="text-[10px] font-bold text-error uppercase tracking-widest">
                  <%= ms.vaccines.filter(v => !v.done).length %> mũi chưa tiêm — đã quá lịch!
                </p>
              </div>
              <% } %>
            </div>
          </div>

          <%# Vaccines at this milestone %>
          <% if (ms.vaccines.length > 0) { %>
          <div class="!ml-14 space-y-2">
            <% ms.vaccines.forEach(v => { %>
              <% const doneBadge = v.done
                ? 'bg-secondary/10 text-secondary border-secondary/20'
                : v.late
                  ? 'bg-warning/10 text-warning border-warning/20'
                  : 'bg-outline/50 text-on-surface-variant border-outline/20';
              %>
              <div class="flex items-center justify-between p-3 bg-surface rounded-xl border <%= v.done ? 'border-secondary/20' : 'border-outline' %>">
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  <% if (v.done) { %>
                  <span class="material-symbols-outlined text-secondary text-lg shrink-0">check_circle</span>
                  <% } else { %>
                  <span class="material-symbols-outlined text-on-surface-variant text-lg shrink-0">radio_button_unchecked</span>
                  <% } %>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-black text-on-surface truncate <%= v.done ? 'line-through opacity-60' : '' %>"><%= v.name %></p>
                    <p class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">
                      <%= v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng' : '') %>
                    </p>
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="v-badge <%= doneBadge %>">
                    <%= v.done ? 'Đã tiêm' : v.late ? 'Tiêm trễ' : 'Chưa tiêm' %>
                  </span>
                  <% if (!v.done && v.stock > 0) { %>
                  <a href="/appointments/book?childId=<%= c.id %>&vaccineId=<%= v.id %>"
                     class="v-btn v-btn-primary v-btn-sm no-underline !py-1.5 !px-3">
                    <span class="material-symbols-outlined v-icon-12">add</span>
                  </a>
                  <% } else if (!v.done && v.stock <= 0) { %>
                  <span class="v-badge bg-error/10 text-error border border-error/20 !text-[9px]">Hết hàng</span>
                  <% } %>
                </div>
              </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="!ml-14 py-2">
            <p class="text-[10px] font-bold text-on-surface-variant/50 italic uppercase tracking-widest">Không có mũi tiêm nào tại mốc này</p>
          </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>

  <%# ============ CTA ============ %>
  <div class="v-card !p-6 !bg-gradient-to-r !from-surface !to-secondary/5 !border-secondary/20 !border-2">
    <div class="flex flex-col sm:flex-row items-center gap-4 justify-between">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 bg-secondary/10 rounded-xl flex items-center justify-center shrink-0">
          <span class="material-symbols-outlined text-secondary text-2xl">event_available</span>
        </div>
        <div>
          <p class="font-black text-on-surface">Đặt lịch tiêm ngay</p>
          <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mt-0.5">Tiêm đúng lịch, bảo vệ bé toàn diện</p>
        </div>
      </div>
      <a href="/appointments/book?childId=<%= c.id %>" class="v-btn v-btn-primary no-underline shrink-0">
        <span class="material-symbols-outlined v-icon-16">calendar_add_on</span>
        Đặt lịch tiêm
      </a>
    </div>
  </div>

</div>
