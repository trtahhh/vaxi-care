<!-- =====================
  Child Detail (Client)
  Data: child, appointments[], error
===================== -->

<% if (locals.error || !locals.child) { %>
  <%- include('../partials/empty-state', {
      icon: 'child_care',
      title: 'Không tìm thấy hồ sơ bé',
      message: locals.error || '',
      actionLabel: 'Quay lại Dashboard',
      actionHref: '/client/dashboard'
  }) %>
<% } else { %>

<%- include('../partials/client-page-header', {
    title: 'Hồ sơ: ' + child.name,
    subtitle: 'Thông tin sổ tiêm và lịch sử mũi tiêm',
    backHref: '/client/dashboard'
}) %>

<%
  const appts = appointments || [];
  const now = new Date();
  const todayStart = new Date(now.getFullYear(), now.getMonth(), now.getDate());

  const completed = appts.filter(a => a.status === 'completed');
  const confirmed = appts.filter(a => a.status === 'confirmed');
  const pending = appts.filter(a => a.status === 'pending');
  const cancelled = appts.filter(a => a.status === 'cancelled');
  const missed = appts.filter(a => a.status !== 'cancelled' && a.status !== 'completed' && new Date(a.date) < todayStart);
  const upcoming = [...confirmed, ...pending].filter(a => new Date(a.date) >= todayStart);

  const completedNames = completed.map(a => a.vaccine && a.vaccine.name ? a.vaccine.name : 'Vắc xin').slice(0, 5);

  const dob = new Date(child.dob);
  const months = (now.getFullYear() - dob.getFullYear()) * 12 + (now.getMonth() - dob.getMonth());
  const ageStr = months < 12 ? months + ' tháng'
    : Math.floor(months / 12) + ' tuổi' + (months % 12 > 0 ? ', ' + (months % 12) + ' tháng' : '');
%>

<div class="space-y-8 animate-fade-in">

  <%# Child profile card %>
  <div class="v-card !p-8">
    <div class="flex flex-col md:flex-row md:items-center gap-6">
      <div class="w-20 h-20 rounded-2xl <%= child.gender === 'male' ? 'bg-primary' : 'bg-error' %> text-white flex items-center justify-center shrink-0 shadow-lg">
        <span class="material-symbols-outlined text-5xl"><%= child.gender === 'male' ? 'boy' : 'girl' %></span>
      </div>
      <div class="flex-1">
        <h2 class="text-4xl font-display font-black uppercase tracking-tight text-on-surface leading-none mb-1"><%= child.name %></h2>
        <div class="flex flex-wrap items-center gap-3 mt-2">
          <span class="v-badge <%= child.gender === 'male' ? 'bg-primary/10 text-primary border-primary/20' : 'bg-error/10 text-error border-error/20' %>">
            <%= child.gender === 'male' ? 'NAM' : 'NỮ' %>
          </span>
          <span class="text-[10px] font-black text-on-surface-variant uppercase tracking-widest">Sinh: <%= child.dob ? dob.toLocaleDateString('vi-VN') : '' %></span>
          <span class="text-[10px] font-black text-primary uppercase tracking-widest"><%= ageStr %></span>
        </div>
      </div>
      <a href="/client/roadmap/<%= child.id %>" class="v-btn v-btn-secondary !py-3 !px-5 !text-[10px] uppercase tracking-widest gap-2">
        <span class="material-symbols-outlined text-sm">timeline</span>
        Lộ trình
      </a>
      <a href="/appointments/book?childId=<%= child.id %>" class="v-btn v-btn-primary !py-3 !px-6 !text-[10px] uppercase tracking-widest gap-2">
        <span class="material-symbols-outlined text-sm">event_available</span>
        Đặt lịch tiêm
      </a>
    </div>
  </div>

  <%# Stats + Charts row %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    <%# Status breakdown %>
    <div class="v-card !p-6">
      <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-2xl">bar_chart</span>
        Tổng quan lịch tiêm
      </h3>
      <div class="space-y-3">
        <div class="flex items-center justify-between p-3 bg-success/5 rounded-xl border border-success/20">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-success/10 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-success text-base">check_circle</span></div>
            <span class="text-sm font-black text-on-surface">Hoàn thành</span>
          </div>
          <span class="text-xl font-black text-success"><%= completed.length %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-primary/5 rounded-xl border border-primary/20">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-primary/10 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-primary text-base">schedule</span></div>
            <span class="text-sm font-black text-on-surface">Sắp tới</span>
          </div>
          <span class="text-xl font-black text-primary"><%= upcoming.length %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-warning/5 rounded-xl border border-warning/20">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-warning/10 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-warning text-base">pending</span></div>
            <span class="text-sm font-black text-on-surface">Chờ duyệt</span>
          </div>
          <span class="text-xl font-black text-warning"><%= pending.length %></span>
        </div>
        <div class="flex items-center justify-between p-3 bg-error/5 rounded-xl border border-error/20">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-error/10 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-error text-base">cancel</span></div>
            <span class="text-sm font-black text-on-surface">Đã hủy</span>
          </div>
          <span class="text-xl font-black text-error"><%= cancelled.length %></span>
        </div>
        <% if (missed.length > 0) { %>
        <div class="flex items-center justify-between p-3 bg-error/10 rounded-xl border border-error/30">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-error/20 rounded-lg flex items-center justify-center"><span class="material-symbols-outlined text-error text-base">warning</span></div>
            <span class="text-sm font-black text-error">Bỏ lỡ lịch</span>
          </div>
          <span class="text-xl font-black text-error"><%= missed.length %></span>
        </div>
        <% } %>
      </div>
    </div>

    <%# Doughnut chart %>
    <div class="v-card !p-6 flex flex-col items-center">
      <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface mb-2 flex items-center gap-2 w-full">
        <span class="material-symbols-outlined text-secondary text-2xl">pie_chart</span>
        Tỷ lệ hoàn thành
      </h3>
      <div class="flex-1 flex items-center justify-center">
        <div class="relative">
          <canvas id="coverageChart" width="180" height="180"
                  data-completed="<%= completed.length %>"
                  data-upcoming="<%= upcoming.length %>"
                  data-pending="<%= pending.length %>"
                  data-cancelled="<%= cancelled.length %>"
                  data-missed="<%= missed.length %>"></canvas>
          <div class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none">
            <span class="text-2xl font-black text-on-surface"><%= completed.length %></span>
            <span class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">mũi xong</span>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-x-6 gap-y-1 mt-2 w-full">
        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-success"></span><span class="text-[10px] font-bold text-on-surface-variant">Hoàn thành: <%= completed.length %></span></div>
        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-primary"></span><span class="text-[10px] font-bold text-on-surface-variant">Sắp tới: <%= upcoming.length %></span></div>
        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-warning"></span><span class="text-[10px] font-bold text-on-surface-variant">Chờ duyệt: <%= pending.length %></span></div>
        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-error"></span><span class="text-[10px] font-bold text-on-surface-variant">Hủy/lỡ: <%= cancelled.length + missed.length %></span></div>
      </div>
    </div>

    <%# Recent completed vaccines %>
    <div class="v-card !p-6">
      <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-success text-2xl">verified</span>
        Mũi tiêm đã hoàn thành
      </h3>
      <% if (completed.length === 0) { %>
        <div class="py-10 text-center opacity-50">
          <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-3 block">vaccines</span>
          <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Chưa có mũi tiêm nào hoàn thành</p>
        </div>
      <% } else { %>
        <div class="space-y-2 max-h-[280px] overflow-y-auto custom-scrollbar pr-1">
          <% completed.forEach(a => { %>
            <div class="flex items-center gap-3 p-2 bg-success/5 rounded-xl border border-success/15">
              <div class="w-7 h-7 bg-success/10 rounded-lg flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-success text-sm">check</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-black text-on-surface truncate"><%= a.vaccine && a.vaccine.name ? a.vaccine.name : 'Vắc xin' %></p>
                <p class="text-[9px] font-bold text-on-surface-variant uppercase tracking-widest">
                  <%= new Date(a.date).toLocaleDateString('vi-VN') %>
                  <% if (a.session) { %>
                    · <%= a.session === 'morning' ? 'Sáng' : 'Chiều' %>
                  <% } %>
                </p>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>

  <%# Upcoming appointments highlight %>
  <% if (upcoming.length > 0) { %>
  <div class="v-card !p-6 !bg-gradient-to-r !from-primary !to-[#2B6CB0] !border-none">
    <h3 class="text-xl font-display font-black text-white mb-4 flex items-center gap-2">
      <span class="material-symbols-outlined text-white/80 text-2xl">upcoming</span>
      Lịch tiêm sắp tới
    </h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      <% upcoming.forEach(a => { %>
        <div class="bg-white/15 backdrop-blur rounded-xl p-4 border border-white/20">
          <div class="flex items-start justify-between gap-2 mb-2">
            <p class="text-sm font-black text-white"><%= a.vaccine && a.vaccine.name ? a.vaccine.name : 'Vắc xin' %></p>
            <span class="v-badge <%= a.status === 'confirmed' ? 'bg-success text-white border-0' : 'bg-warning text-white border-0' %> text-[9px]">
              <%= a.status === 'confirmed' ? 'Đã xác nhận' : 'Chờ duyệt' %>
            </span>
          </div>
          <div class="flex items-center gap-2 text-white/80 text-[10px] font-bold">
            <span class="material-symbols-outlined text-white/60 text-sm">calendar_today</span>
            <%= new Date(a.date).toLocaleDateString('vi-VN', { weekday: 'short', day: 'numeric', month: 'short' }) %>
            <span class="w-1 h-1 rounded-full bg-white/40"></span>
            <span class="material-symbols-outlined text-white/60 text-sm"><%= a.session === 'morning' ? 'wb_sunny' : 'dark_mode' %></span>
            <%= a.session === 'morning' ? 'Sáng' : 'Chiều' %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>

  <%# Appointment history table %>
  <div class="v-card !p-0 overflow-hidden">
    <div class="px-8 py-6 border-b border-outline/50 bg-background/50 flex items-center justify-between">
      <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface">Lịch sử tiêm chủng</h3>
      <span class="v-badge bg-primary/10 text-primary border-primary/20"><%= appts.length %> bản ghi</span>
    </div>

    <% if (appts.length === 0) { %>
      <div class="p-12 text-center opacity-60">
        <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-3 block">event_busy</span>
        <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Chưa có lịch sử tiêm chủng</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
              <th class="px-6 py-4">Ngày</th>
              <th class="px-6 py-4">Vắc xin</th>
              <th class="px-6 py-4">Buổi</th>
              <th class="px-6 py-4">Trạng thái</th>
              <th class="px-6 py-4">Ghi chú</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline">
            <% appts.forEach(a => { %>
              <% const isPast = new Date(a.date) < todayStart && a.status !== 'completed' && a.status !== 'cancelled'; %>
              <tr class="hover:bg-primary/5 transition-colors <%= isPast ? 'opacity-60' : '' %>">
                <td class="px-6 py-4">
                  <p class="font-black text-sm text-on-surface uppercase"><%= new Date(a.date).toLocaleDateString('vi-VN') %></p>
                  <p class="text-[10px] font-bold text-on-surface-variant uppercase mt-0.5">
                    <%= new Date(a.date).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }) %>
                  </p>
                </td>
                <td class="px-6 py-4">
                  <p class="font-black text-sm text-on-surface uppercase tracking-tight"><%= a.vaccine && a.vaccine.name ? a.vaccine.name : 'Vắc xin' %></p>
                  <% if (a.vaccine && a.vaccine.price) { %>
                    <p class="text-[10px] font-bold text-on-surface-variant mt-0.5"><%= new Intl.NumberFormat('vi-VN').format(a.vaccine.price) %>đ</p>
                  <% } %>
                </td>
                <td class="px-6 py-4">
                  <span class="text-xs font-black px-2 py-1 rounded-lg <%= a.session === 'morning' ? 'bg-warning/10 text-warning border border-warning/20' : 'bg-secondary/10 text-secondary border border-secondary/20' %>">
                    <span class="material-symbols-outlined v-icon-12 align-middle"><%= a.session === 'morning' ? 'wb_sunny' : 'dark_mode' %></span>
                    <%= a.session === 'morning' ? 'Sáng' : 'Chiều' %>
                  </span>
                </td>
                <td class="px-6 py-4">
                  <%- include('../partials/status-badge', { status: a.status }) %>
                </td>
                <td class="px-6 py-4 text-xs font-medium text-on-surface-variant italic max-w-[200px] truncate"><%= a.notes || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const ctx = document.getElementById('coverageChart');
  if (ctx) {
    const completed = parseInt(ctx.dataset.completed || '0');
    const upcoming = parseInt(ctx.dataset.upcoming || '0');
    const pending = parseInt(ctx.dataset.pending || '0');
    const cancelled = parseInt(ctx.dataset.cancelled || '0');
    const missed = parseInt(ctx.dataset.missed || '0');
    const total = completed + upcoming + pending + cancelled + missed;

    if (total > 0) {
      new Chart(ctx.getContext('2d'), {
        type: 'doughnut',
        data: {
          labels: ['Hoàn thành', 'Sắp tới', 'Chờ duyệt', 'Hủy / Bỏ lỡ'],
          datasets: [{
            data: [completed, upcoming, pending, cancelled + missed],
            backgroundColor: ['#2F855A', '#3182CE', '#D97706', '#E53E3E'],
            borderWidth: 3,
            borderColor: '#fff',
            hoverOffset: 5
          }]
        },
        options: {
          responsive: false,
          cutout: '68%',
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: ctx => ` ${ctx.label}: ${ctx.raw} (${Math.round(ctx.raw / total * 100)}%)`
              }
            }
          }
        }
      });
    }
  }
});
</script>
<% } %>
