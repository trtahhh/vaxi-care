<!-- =====================
  Book Appointment
  Data: children[], vaccines[], recommendations[], selectedChildId, error
===================== -->

<%- include('../partials/client-page-header', {
    title: 'Đặt lịch tiêm chủng',
    subtitle: 'Lên kế hoạch bảo vệ bé yêu.',
    backHref: '/client/dashboard'
}) %>

<% const safeChildren = children || []; %>
<% const safeVaccines = vaccines || []; %>
<% const safeRecs = recommendations || []; %>
<% const selId = selectedChildId; %>
<% const minDate = new Date().toISOString().slice(0, 16); %>

<%# Error alert %>
<% if (locals.error) { %>
  <div class="mb-6 p-4 rounded-xl bg-error text-white flex items-center gap-3 shadow-lg shadow-error/20 animate-shake">
    <span class="material-symbols-outlined text-xl">report</span>
    <p class="font-black text-xs uppercase tracking-widest flex-1"><%= error %></p>
  </div>
<% } %>

<form action="/appointments/book" method="POST" id="booking-form" class="space-y-12 pb-24 animate-fade-in">

  <%# Hidden fields %>
  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <% } %>

  <%# ---- Step 1: Select child ---- %>
  <div>
    <div class="flex items-center gap-4 mb-8">
      <span class="w-12 h-12 bg-primary text-white rounded-2xl flex items-center justify-center font-display font-black text-xl shadow-lg shadow-primary/20">01</span>
      <h2 class="text-2xl font-display font-black uppercase tracking-tight text-on-surface leading-none">Chọn hồ sơ bé</h2>
    </div>

    <% if (safeChildren.length === 0) { %>
      <div class="v-card !border-dashed !p-10 text-center">
        <p class="text-xs font-black text-error uppercase tracking-widest mb-4">Chưa có hồ sơ trẻ trong hệ thống.</p>
        <% if (locals.user && (locals.user.role === 'admin' || locals.user.role === 'staff')) { %>
          <a href="/children/add" class="v-btn v-btn-secondary inline-flex">THÊM BÉ NGAY</a>
        <% } else { %>
          <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mt-2">Vui lòng đến trung tâm tiêm chủng để tạo hồ sơ cho bé.</p>
        <% } %>
      </div>
    <% } else { %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% safeChildren.forEach((c) => {
            const birth = new Date(c.dob);
            const isSelected = selId ? selId == c.id : (safeChildren.length === 1);
        %>
          <label class="v-card !p-6 relative cursor-pointer border-2 transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5
              <%= isSelected ? 'border-primary' : 'border-outline' %>">
            <input type="radio" name="childId" value="<%= c.id %>" class="peer hidden" required <%= isSelected ? 'checked' : '' %>>
            <div class="flex items-center gap-5">
              <div class="w-12 h-12 rounded-xl bg-background border-2 flex items-center justify-center
                  <%= isSelected ? 'border-primary text-primary' : 'border-outline text-on-surface-variant' %>">
                <span class="material-symbols-outlined text-3xl">child_care</span>
              </div>
              <div class="flex-1">
                <p class="font-black text-base text-on-surface uppercase tracking-tight"><%= c.name %></p>
                <p class="text-[10px] font-bold text-on-surface-variant uppercase mt-0.5 tracking-widest">
                  SINH: <%= birth.toLocaleDateString('vi-VN') %>
                </p>
              </div>
              <div class="opacity-0 group-has-[:checked]:opacity-100 transition-opacity">
                <span class="material-symbols-outlined text-primary">check_circle</span>
              </div>
            </div>
          </label>
        <% }) %>
      </div>
    <% } %>
  </div>

  <%# ---- Step 2: Select vaccine ---- %>
  <div>
    <div class="flex items-center gap-4 mb-8">
      <span class="w-12 h-12 bg-primary text-white rounded-2xl flex items-center justify-center font-display font-black text-xl shadow-lg shadow-primary/20">02</span>
      <h2 class="text-2xl font-display font-black uppercase tracking-tight text-on-surface leading-none">Chọn vắc xin</h2>
      <% if (safeRecs.length > 0) { %>
        <span class="v-badge bg-secondary text-white border-transparent ml-auto"><%= safeRecs.length %> gợi ý</span>
      <% } %>
    </div>

    <div class="v-card !p-0 overflow-hidden border-2 shadow-lg">
      <div class="p-4 bg-background border-b-2 border-outline flex items-center gap-3">
        <span class="material-symbols-outlined text-primary">search</span>
        <input id="vaccine-search" type="text" placeholder="NHẬP TÊN VẮC XIN..."
               class="bg-transparent border-none focus:ring-0 text-on-surface w-full font-black text-sm uppercase tracking-widest outline-none placeholder:opacity-30">
      </div>
      <div id="vaccine-list" class="max-h-[400px] overflow-y-auto p-5 grid grid-cols-1 md:grid-cols-2 gap-3 custom-scrollbar">
        <% safeVaccines.forEach(v => {
            const rec = safeRecs.some(r => r.id === v.id);
        %>
          <div class="vaccine-item" data-name="<%= v.name.toLowerCase() %>">
            <label class="v-card !p-4 flex items-center justify-between cursor-pointer border-2 transition-all group
                <%= rec ? 'border-secondary/40' : 'border-outline/50' %>
                has-[:checked]:border-primary has-[:checked]:bg-primary/5">
              <input type="radio" name="vaccineId" value="<%= v.id %>" class="peer hidden" required>
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg flex items-center justify-center border transition-all
                    <%= rec ? 'bg-secondary text-white border-secondary' : 'bg-background text-on-surface-variant border-outline' %>">
                  <span class="material-symbols-outlined text-lg"><%= rec ? 'verified' : 'vaccines' %></span>
                </div>
                <div>
                  <p class="font-black text-sm text-on-surface uppercase tracking-tight"><%= v.name %></p>
                  <p class="text-[9px] font-bold text-on-surface-variant uppercase mt-0.5 tracking-widest">
                    <%= v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng' : '') %>
                  </p>
                </div>
              </div>
              <span class="text-xs font-black text-primary bg-primary/5 px-2 py-1 rounded border border-primary/10 shrink-0">
                <%= new Intl.NumberFormat('vi-VN').format(v.price) %>đ
              </span>
            </label>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <%# ---- Step 3: Date & Notes ---- %>
  <div>
    <div class="flex items-center gap-4 mb-8">
      <span class="w-12 h-12 bg-primary text-white rounded-2xl flex items-center justify-center font-display font-black text-xl shadow-lg shadow-primary/20">03</span>
      <h2 class="text-2xl font-display font-black uppercase tracking-tight text-on-surface leading-none">Thời gian & Ghi chú</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="v-card !p-8">
        <label class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-base text-primary">calendar_today</span>
          NGÀY VÀ GIỜ TIÊM
        </label>
        <input type="datetime-local" name="date" min="<%= minDate %>" required
               onchange="checkSlots(event)"
               class="w-full bg-background border-2 border-outline rounded-xl px-6 py-4 text-on-surface font-black text-base outline-none focus:border-primary transition-all">
        <div id="slot-info-box" class="hidden mt-4 p-3 rounded-xl text-[10px] font-black uppercase tracking-widest"></div>
      </div>

      <div class="v-card !p-8">
        <label class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-base text-primary">sticky_note_2</span>
          GHI CHÚ (DỊ ỨNG, BỆNH NỀN...)
        </label>
        <textarea name="notes" rows="4" placeholder="VD: Dị ứng hải sản..."
                  class="w-full bg-background border-2 border-outline rounded-xl px-6 py-4 text-on-surface font-bold text-sm outline-none focus:border-primary transition-all resize-none"></textarea>
      </div>
    </div>
  </div>

  <%# ---- CTA ---- %>
  <div class="v-card !p-12 !bg-primary !border-none text-center shadow-2xl shadow-primary/30 rounded-3xl">
    <p class="text-white/80 font-bold text-xs uppercase tracking-widest mb-6 border-b border-white/20 pb-4 inline-block">BƯỚC CUỐI CÙNG</p>
    <button type="submit" id="submit-btn"
            class="v-btn !bg-white !text-primary !py-5 !px-16 !text-lg !font-black !rounded-2xl shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all uppercase tracking-widest gap-3 mx-auto w-full sm:w-auto"
            <%= safeChildren.length === 0 ? 'disabled' : '' %>>
      <span class="material-symbols-outlined text-2xl">event_available</span>
      XÁC NHẬN ĐĂNG KÝ TIÊM
    </button>
  </div>
</form>

<script>
  async function checkSlots(e) {
    const box = document.getElementById('slot-info-box');
    const btn = document.getElementById('submit-btn');
    const date = e.target.value;
    if (!date) return;
    try {
      const r = await fetch('/appointments/slots?date=' + date);
      const d = await r.json();
      box.classList.remove('hidden', 'bg-secondary/10', 'text-secondary', 'border-secondary/20', 'bg-error/10', 'text-error', 'border-error/20');
      if (d.availableSlots > 0) {
        box.classList.add('bg-secondary/10', 'text-secondary', 'border-secondary/20');
        box.innerHTML = '<span class="material-symbols-outlined text-sm">check_circle</span> CÒN ' + d.availableSlots + ' SUẤT';
        btn.disabled = false;
      } else {
        box.classList.add('bg-error/10', 'text-error', 'border-error/20');
        box.innerHTML = '<span class="material-symbols-outlined text-sm">cancel</span> HẾT CHỖ';
        btn.disabled = true;
      }
    } catch(err) { console.error(err); }
  }

  document.getElementById('vaccine-search').addEventListener('input', function(e) {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.vaccine-item').forEach(el => {
      const name = el.getAttribute('data-name');
      el.style.display = name && name.includes(q) ? '' : 'none';
    });
  });
</script>
