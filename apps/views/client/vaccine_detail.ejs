<%- include('layout', { 
    currentPath: '/client/vaccines', 
    title: 'Chi tiết Vắc xin - VaxiCare',
    body: `

<!-- Page Header -->
<section class="mb-10 flex items-center justify-between animate-fade-in">
    <div class="flex items-center gap-4">
        <a href="javascript:history.back()" class="w-10 h-10 flex items-center justify-center rounded-lg bg-surface border border-outline text-on-surface-variant hover:text-primary transition-all shadow-sm">
            <span class="material-symbols-outlined">arrow_back</span>
        </a>
        <h1 class="text-3xl v-title tracking-tight uppercase">Chi tiết Vắc xin</h1>
    </div>
</section>

<!-- Vaccine Identity -->
<section class="v-card !p-10 !border-primary border-2 mb-10 animate-fade-in" style="animation-delay: 0.1s">
    <div class="absolute top-6 right-8">
        <span class="v-badge bg-secondary text-white border-transparent gap-1.5 shadow-sm">
            <span class="material-symbols-outlined text-[14px]">check_circle</span>
            ĐANG CÓ SẴN
        </span>
    </div>
    
    <div class="space-y-6">
        <div class="space-y-1">
            <p class="text-[10px] font-black uppercase text-on-surface-variant tracking-[0.2em] opacity-60">Sản phẩm sinh phẩm</p>
            <h2 class="text-5xl v-title leading-tight uppercase text-on-surface">
                <%= typeof vaccine !== 'undefined' ? vaccine.name : 'VẮC XIN 5 TRONG 1' %><br/>
                <span class="text-primary tracking-normal font-medium text-2xl lowercase opacity-80">(<%= typeof vaccine !== 'undefined' ? vaccine.type : 'Quinvaxem' %>)</span>
            </h2>
        </div>
        
        <div class="flex flex-wrap items-center gap-10 pt-6 mt-6 border-t border-outline/50">
            <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase text-on-surface-variant tracking-widest mb-2">Chi phí dịch vụ</span>
                <span class="text-4xl font-black text-primary tracking-tighter"><%= typeof vaccine !== 'undefined' ? vaccine.price.toLocaleString('vi-VN') : '0' %>đ</span>
            </div>
            <div class="w-px h-12 bg-outline hidden md:block"></div>
            <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase text-on-surface-variant tracking-widest mb-2">Loại vắc xin</span>
                <span class="text-lg font-black text-on-surface uppercase"><%= typeof vaccine !== 'undefined' ? vaccine.type : 'Vắc xin hỗn hợp' %></span>
            </div>
        </div>
    </div>
</section>

<!-- Detailed Info Bento -->
<section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-40 animate-fade-in" style="animation-delay: 0.2s">
    <!-- Purpose Card -->
    <div class="col-span-1 md:col-span-2 v-card !p-10">
        <div class="flex items-center gap-5 mb-8">
            <div class="w-14 h-14 bg-primary text-white rounded-2xl flex items-center justify-center shadow-lg shadow-primary/20">
                <span class="material-symbols-outlined text-3xl">verified_user</span>
            </div>
            <div>
                <h3 class="v-title text-xl uppercase tracking-tight">Mục tiêu bảo vệ lâm sàng</h3>
                <p class="text-xs text-on-surface-variant font-bold uppercase tracking-widest opacity-60 mt-0.5">Phòng ngừa các bệnh truyền nhiễm nguy hiểm ở trẻ nhỏ.</p>
            </div>
        </div>
        <div class="flex flex-wrap gap-3">
            <% ['Bạch hầu', 'Ho gà', 'Uốn ván', 'Viêm gan B', 'Hib'].forEach(target => { %>
                <span class="px-4 py-2 bg-background border border-outline rounded-xl text-[10px] font-black text-on-surface-variant uppercase tracking-widest hover:border-primary hover:text-primary transition-all cursor-default">
                    <%= target %>
                </span>
            <% }) %>
        </div>
    </div>

    <!-- Side Effects -->
    <div class="v-card !p-10 flex flex-col">
        <div class="w-12 h-12 bg-warning text-white rounded-xl flex items-center justify-center mb-8 shadow-lg shadow-warning/20">
            <span class="material-symbols-outlined text-2xl">medical_information</span>
        </div>
        <h3 class="v-title text-[15px] uppercase tracking-widest mb-6">Phản ứng sau tiêm chủng</h3>
        <div class="space-y-4 flex-1">
            <div class="flex items-center gap-4 p-4 rounded-xl bg-background border border-outline group hover:border-warning/30 transition-all">
                <div class="w-2 h-2 rounded-full bg-warning"></div>
                <span class="text-xs font-black text-on-surface-variant uppercase tracking-tight group-hover:text-on-surface">Sốt nhẹ sau khi tiêm (37.5°C - 38.5°C)</span>
            </div>
            <div class="flex items-center gap-4 p-4 rounded-xl bg-background border border-outline group hover:border-warning/30 transition-all">
                <div class="w-2 h-2 rounded-full bg-warning"></div>
                <span class="text-xs font-black text-on-surface-variant uppercase tracking-tight group-hover:text-on-surface">Sưng đỏ, đau nhẹ tại vị trí tiêm</span>
            </div>
        </div>
    </div>

    <!-- Schedule -->
    <div class="v-card !p-10 flex flex-col">
        <div class="w-12 h-12 bg-secondary text-white rounded-xl flex items-center justify-center mb-8 shadow-lg shadow-secondary/20">
            <span class="material-symbols-outlined text-2xl">event_repeat</span>
        </div>
        <h3 class="v-title text-[15px] uppercase tracking-widest mb-6">Phác đồ đề nghị (WHO)</h3>
        <div class="space-y-6">
            <div class="flex justify-between items-center">
                <span class="text-[10px] font-black uppercase text-on-surface-variant tracking-widest">Số mũi tiêm cơ bản</span>
                <span class="v-badge bg-primary/10 text-primary border-primary/20">03 MŨI TIÊM</span>
            </div>
            <div class="w-full h-3 bg-background border border-outline rounded-full overflow-hidden p-0.5">
                <div class="w-1/3 h-full bg-primary rounded-full"></div>
            </div>
            <div class="p-4 bg-primary/5 rounded-xl border border-primary/10">
                <p class="text-[10px] font-black text-primary uppercase tracking-widest text-center">Tiêm lúc trẻ được 2, 3 và 4 tháng tuổi.</p>
            </div>
        </div>
    </div>
</section>

<!-- Action Fixed Bar -->
<div class="fixed bottom-10 left-0 w-full px-6 flex justify-center pointer-events-none z-50 animate-slide-up">
    <div class="w-full max-w-2xl pointer-events-auto">
        <a href="/appointments/book" class="v-btn v-btn-primary !py-5 gap-3 w-full shadow-2xl shadow-primary/40 !rounded-2xl uppercase tracking-[0.2em]">
            <span class="material-symbols-outlined">calendar_add_on</span>
            ĐẶT LỊCH TIÊM CHỦNG NGAY
        </a>
    </div>
</div>

` }) %>
