<!-- =====================
  Vaccine Detail
  Data: vaccine, error
===================== -->

<%- include('../partials/client-page-header', {
    title: v.name,
    subtitle: v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng tuổi' : 'Mọi lứa tuổi'),
    backHref: '/client/vaccines',
    backIcon: 'arrow_back'
}) %>

<% const v = locals.vaccine || null; %>

<%# Error state %>
<% if (locals.error || !v) { %>
  <%- include('../partials/empty-state', {
      icon: 'vaccines',
      title: 'Không tìm thấy vắc xin',
      message: locals.error || '',
      actionLabel: 'Quay lại Dashboard',
      actionHref: '/client/dashboard'
  }) %>
  <% return; %>
<% } %>

<div class="space-y-6 animate-fade-in">

  <%# Vaccine Identity Card %>
  <div class="v-card !p-8 !border-primary/30 relative overflow-hidden">
    <%# Gradient accent %>
    <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-primary to-[#2B6CB0]"></div>

    <%# Stock badge %>
    <div class="absolute top-6 right-6">
      <% if ((v.stock || 0) <= 0) { %>
        <span class="v-badge v-badge-error gap-1">
          <span class="material-symbols-outlined text-[12px]">cancel</span>
          HẾT HÀNG
        </span>
      <% } else if ((v.stock || 0) <= 10) { %>
        <span class="v-badge v-badge-warning gap-1">
          <span class="material-symbols-outlined text-[12px]">warning</span>
          SẮP HẾT (<%= v.stock %> còn)
        </span>
      <% } else { %>
        <span class="v-badge v-badge-secondary gap-1">
          <span class="material-symbols-outlined text-[12px]">check_circle</span>
          CÒN HÀNG
        </span>
      <% } %>
    </div>

    <%# Info %>
    <div class="pr-24 mb-6">
      <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mb-2">Thông tin vaccine</p>
      <h2 class="text-4xl font-display font-black tracking-tight text-on-surface leading-none mt-1">
        <%= v.name %>
      </h2>
      <% if (v.type) { %>
        <p class="text-sm font-medium text-primary mt-1"><%= v.type %></p>
      <% } %>
    </div>

    <%# Stats row %>
    <div class="flex flex-wrap gap-6 pt-6 border-t border-outline">
      <div>
        <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest mb-1">Chi phí</p>
        <p class="text-2xl font-black text-primary tracking-tight">
          <%= new Intl.NumberFormat('vi-VN').format(v.price) %>đ
        </p>
      </div>
      <div class="border-l border-outline pl-6">
        <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest mb-1">Độ tuổi</p>
        <p class="text-base font-bold text-on-surface"><%= v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng' : 'Mọi lứa tuổi') %></p>
      </div>
      <div class="border-l border-outline pl-6">
        <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest mb-1">Tồn kho</p>
        <p class="text-base font-bold <%= (v.stock || 0) <= 10 ? 'text-error' : 'text-secondary' %>">
          <%= (v.stock || 0) %> liều
        </p>
      </div>
    </div>
  </div>

  <%# Description %>
  <% if (v.description) { %>
    <div class="v-card !p-8">
      <h3 class="text-sm font-black uppercase tracking-tight text-on-surface mb-3">Mô tả vaccine</h3>
      <p class="text-sm font-medium text-on-surface-variant leading-relaxed"><%= v.description %></p>
    </div>
  <% } %>

  <%# CTA %>
  <div class="v-card !p-6 !bg-primary !border-none text-center shadow-xl shadow-primary/30">
    <p class="text-white/60 text-[10px] font-bold uppercase tracking-widest mb-4">Đặt lịch tiêm chủng cho bé yêu</p>
    <a href="/appointments/book?vaccineId=<%= v.id %>"
       class="v-btn !bg-white !text-primary !py-4 !px-10 shadow-lg hover:shadow-xl transition-all uppercase tracking-widest gap-2">
      <span class="material-symbols-outlined v-icon-20">calendar_add_on</span>
      Đặt lịch ngay
    </a>
  </div>
</div>
