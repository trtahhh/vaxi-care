<%#
  locals:
    icon: string (material-symbols icon name)
    title: string
    message: string
    actionLabel: string (optional)
    actionHref: string (optional)
    actionIcon: string (optional)
    variant: 'default' | 'compact'
%>
<%
const pIcon = locals.icon || 'inbox';
const pTitle = locals.title || 'Không có dữ liệu';
const pMessage = locals.message || '';
const pActionLabel = locals.actionLabel || '';
const pActionHref = locals.actionHref || '#';
const pActionIcon = locals.actionIcon || '';
const compact = locals.variant === 'compact';
%>
<div class="flex flex-col items-center justify-center p-8 sm:p-12 bg-white border border-outline/50 rounded-3xl shadow-sm text-center <%= compact ? 'min-h-[250px]' : 'min-h-[400px]' %>">
    <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-[2rem] bg-background flex items-center justify-center mb-6 shadow-inner text-on-surface-variant/40 transform hover:scale-110 transition-transform duration-500">
        <span class="material-symbols-outlined <%= compact ? 'text-[40px]' : 'text-[48px]' %>"><%= pIcon %></span>
    </div>
    <h3 class="text-xl sm:text-2xl font-display font-black text-on-surface tracking-tight mb-2"><%= pTitle %></h3>
    <% if (pMessage) { %>
        <p class="text-sm font-medium text-on-surface-variant max-w-sm opacity-80 leading-relaxed"><%= pMessage %></p>
    <% } %>
    <% if (pActionLabel) { %>
        <a href="<%= pActionHref %>" class="mt-8 flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white font-bold text-sm tracking-wide px-8 py-3.5 rounded-2xl shadow-primary transition-all duration-300 hover:shadow-primary/50 hover:-translate-y-0.5 no-underline">
            <% if (pActionIcon) { %>
                <span class="material-symbols-outlined text-[20px]"><%= pActionIcon %></span>
            <% } %>
            <%= pActionLabel %>
        </a>
    <% } %>
</div>
