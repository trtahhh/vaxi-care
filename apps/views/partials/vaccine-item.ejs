<%
    const v = locals.vaccine || {};
    const vIsRecommended = locals.isRecommended || false;
    const vShowPrice = locals.showPrice !== false;
    const vSelectable = locals.selectable || false;
%>
<label class="v-card !p-4 flex items-center justify-between cursor-pointer border-2 transition-all group <%= vIsRecommended ? 'border-secondary/40' : 'border-outline/50' %> has-[:checked]:border-primary has-[:checked]:bg-primary/5">
    <div class="flex items-center gap-4">
        <% if (vSelectable) { %>
            <input type="radio" name="vaccineId" value="<%= v.id %>" class="peer hidden" required>
        <% } %>
        <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 transition-all border border-outline shadow-sm
                    <%= vIsRecommended ? 'bg-secondary text-white' : 'bg-background text-on-surface-variant' %> 
                    group-has-[:checked]:bg-primary group-has-[:checked]:text-white">
            <span class="material-symbols-outlined text-xl"><%= vIsRecommended ? 'verified' : 'vaccines' %></span>
        </div>
        <div>
            <div class="flex items-center gap-3">
                <h4 class="text-sm font-black text-on-surface uppercase tracking-tight"><%= v.name || 'Vắc xin' %></h4>
                <% if (vIsRecommended) { %>
                    <span class="v-badge bg-secondary text-white border-transparent text-[8px]">GỢI Ý</span>
                <% } %>
            </div>
            <p class="text-[10px] font-bold text-on-surface-variant uppercase tracking-widest mt-0.5"><%= v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng tuổi' : '') %></p>
        </div>
    </div>
    
    <% if (vShowPrice) { %>
        <div class="text-right">
            <span class="text-xs font-black text-primary bg-primary/5 px-2 py-1 rounded border border-primary/10">
                <%= new Intl.NumberFormat('vi-VN').format(v.price) %>Đ
            </span>
        </div>
    <% } %>
</label>
