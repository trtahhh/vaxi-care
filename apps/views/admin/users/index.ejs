<!-- =====================
  Admin Users Index
  Data: users[], search, filterRole, currentPage, totalPages
===================== -->

<% const list = users || []; %>
<% const searchVal = search || ''; %>
<% const roleVal = filterRole || ''; %>

<%- include('../../partials/admin-page-header', {
    title: 'Quản lý nhân sự',
    subtitle: 'Điều hành tài khoản Admin, Staff và Phụ huynh',
    actions: [ { label: 'Thêm người dùng', href: '/admin/users/add', icon: 'person_add', variant: 'primary' } ]
}) %>

<%- include('../../partials/admin-filter-bar', {
    action: '/admin/users',
    searchValue: searchVal,
    searchPlaceholder: 'Tìm theo tên đăng nhập hoặc email...',
    selectName: 'role',
    selectOptions: [
      { value: 'admin', label: 'Quản trị viên' },
      { value: 'staff', label: 'Nhân viên y tế' },
      { value: 'parent', label: 'Phụ huynh' }
    ],
    selectValue: roleVal,
    clearHref: '/admin/users'
}) %>

<% if (list.length === 0) { %>
  <%- include('../../partials/empty-state', {
      icon: 'person_off',
      title: 'Không tìm thấy tài khoản',
      message: 'Thử lại với bộ lọc khác hoặc thêm người dùng mới.',
      actionLabel: 'Thêm người dùng',
      actionHref: '/admin/users/add',
      actionIcon: 'person_add'
  }) %>
<% } %>

<% if (list.length > 0) { %>
  <div class="v-card !p-0 overflow-hidden animate-fade-in">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
            <th class="p-5">Tài khoản</th>
            <th class="p-5">Liên hệ</th>
            <th class="p-5">Vai trò</th>
            <th class="p-5">Ngày tạo</th>
            <th class="p-5 text-center">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline">
          <% list.forEach(u => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="p-5">
                <div class="flex items-center gap-4">
                  <div class="w-11 h-11 rounded-xl bg-primary text-white flex items-center justify-center font-black text-lg shadow-sm">
                    <%= u.username ? u.username.charAt(0).toUpperCase() : 'U' %>
                  </div>
                  <div>
                    <p class="font-black text-sm uppercase tracking-tight text-on-surface"><%= u.username %></p>
                    <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mt-0.5">UID: <%= u.id %></p>
                  </div>
                </div>
              </td>
              <td class="p-5">
                <p class="font-black text-sm text-primary"><%= u.email %></p>
                <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mt-0.5"><%= u.phone || 'CHƯA CẬP NHẬT' %></p>
              </td>
              <td class="p-5">
                <% if (u.role === 'admin') { %>
                  <span class="v-badge bg-error text-white border-transparent">ADMIN</span>
                <% } else if (u.role === 'staff') { %>
                  <span class="v-badge bg-secondary text-white border-transparent">STAFF</span>
                <% } else { %>
                  <span class="v-badge bg-primary text-white border-transparent">PARENT</span>
                <% } %>
              </td>
              <td class="p-5 text-[11px] font-bold text-on-surface-variant">
                <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString('vi-VN') : '-' %>
              </td>
              <td class="p-5">
                <div class="flex items-center justify-center gap-2">
                  <% if (u.role === 'parent') { %>
                    <a href="/children/add?parentId=<%= u.id %>" class="w-9 h-9 rounded-lg border border-primary text-primary bg-white hover:bg-primary hover:text-white flex items-center justify-center transition-all" title="Thêm hồ sơ trẻ">
                      <span class="material-symbols-outlined text-lg">child_care</span>
                    </a>
                  <% } %>
                  <a href="/admin/users/add?clone=<%= u.id %>" class="w-9 h-9 rounded-lg border border-outline text-on-surface-variant bg-white hover:text-primary hover:border-primary flex items-center justify-center transition-all" title="Sửa thông tin">
                    <span class="material-symbols-outlined text-lg">edit</span>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%- include('../../partials/pagination', {
      currentPage: currentPage,
      totalPages: totalPages,
      baseUrl: '?page=',
      extraParams: '&search=' + encodeURIComponent(searchVal) + '&role=' + encodeURIComponent(roleVal)
    }) %>
  </div>
<% } %>
