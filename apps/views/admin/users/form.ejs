<!-- =====================
  Admin User Form (Add)
  Data: user, error
===================== -->

<% const u = user || {}; %>
<% const isEdit = !!u.id; %>

<%- include('../../partials/admin-page-header', {
    title: isEdit ? 'Cập nhật người dùng' : 'Thêm người dùng mới',
    subtitle: 'Tạo tài khoản cho phụ huynh / nhân viên / admin',
    backHref: '/admin/users'
}) %>

<% if (locals.error) { %>
  <div class="mb-6 p-4 rounded-xl bg-error/10 border border-error/20 flex items-center gap-3 shadow-lg animate-shake">
    <span class="material-symbols-outlined text-error text-xl">report</span>
    <p class="text-xs font-black uppercase tracking-tight text-error flex-1"><%= error %></p>
  </div>
<% } %>

<div class="v-card !p-8 max-w-4xl animate-fade-in">
  <form method="POST" action="/admin/users/add" class="space-y-8">

    <% if (locals.csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Tên đăng nhập <span class="text-error">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">account_circle</span>
          <input type="text" name="username" required value="<%= u.username || '' %>"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface"
                 placeholder="VD: phuhuynh01">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Email <span class="text-error">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">mail</span>
          <input type="email" name="email" required value="<%= u.email || '' %>"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface"
                 placeholder="mail@example.com">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Mật khẩu <span class="text-error">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">lock</span>
          <input type="password" name="password" required
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface"
                 placeholder="Tối thiểu 6 ký tự">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Vai trò</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">shield_person</span>
          <select name="role" class="w-full pl-12 pr-10 py-3.5 appearance-none bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
            <option value="parent" <%= u.role === 'parent' ? 'selected' : '' %>>Phụ huynh</option>
            <option value="staff" <%= u.role === 'staff' ? 'selected' : '' %>>Nhân viên y tế</option>
            <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Quản trị viên</option>
          </select>
          <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">arrow_drop_down</span>
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Họ và tên</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">badge</span>
          <input type="text" name="fullName" value="<%= u.fullName || '' %>"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface"
                 placeholder="Tên đầy đủ">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Số điện thoại</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">call</span>
          <input type="text" name="phone" value="<%= u.phone || '' %>"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface"
                 placeholder="0xxxxxxxxx">
        </div>
      </div>
    </div>

    <div class="flex items-center gap-3">
      <button type="submit" class="v-btn v-btn-primary !py-3 !px-8 !text-[10px] uppercase tracking-widest gap-2">
        <span class="material-symbols-outlined text-sm">save</span>
        LƯU TÀI KHOẢN
      </button>
      <a href="/admin/users" class="v-btn v-btn-secondary !py-3 !px-8 !text-[10px] uppercase tracking-widest">HỦY</a>
    </div>

  </form>
</div>
