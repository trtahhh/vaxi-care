<!-- =====================
  Admin Vaccines Index
  Data: vaccines[], search, currentPage, totalPages
===================== -->

<% const list = vaccines || []; %>
<% const searchVal = search || ''; %>
<% const totalStock = list.reduce((sum, v) => sum + (v.stock || 0), 0); %>
<% const lowStock = list.filter(v => (v.stock || 0) <= 10).length; %>

<%- include('../../partials/admin-page-header', {
    title: 'Kho Vắc xin',
    subtitle: 'Quản lý tồn kho, giá và trạng thái cung ứng',
    actions: [ { label: 'Nhập kho mới', href: '/admin/vaccines/add', icon: 'add_box', variant: 'primary' } ]
}) %>

<%- include('../../partials/admin-filter-bar', {
    action: '/admin/vaccines',
    searchValue: searchVal,
    searchPlaceholder: 'Tìm vắc xin theo tên...',
    clearHref: '/admin/vaccines'
}) %>

<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6 animate-fade-in">
  <div class="v-card !bg-primary !border-none !p-6 text-white">
    <p class="text-[10px] font-black uppercase tracking-widest opacity-80 mb-2">Tổng liều khả dụng</p>
    <p class="text-4xl sm:text-5xl font-display font-black text-white tracking-tight leading-none mt-1"><%= new Intl.NumberFormat('vi-VN').format(totalStock) %></p>
  </div>
  <div class="v-card !p-6 border-2 border-error">
    <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Sắp hết hàng</p>
    <p class="text-4xl sm:text-5xl font-display font-black text-error tracking-tight leading-none mt-1"><%= lowStock %></p>
  </div>
  <div class="v-card !p-6 border-2 border-secondary">
    <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Danh mục hiện có</p>
    <p class="text-4xl sm:text-5xl font-display font-black text-on-surface tracking-tight leading-none mt-1"><%= list.length %></p>
  </div>
</div>

<% if (list.length === 0) { %>
  <%- include('../../partials/empty-state', {
      icon: 'medication_liquid',
      title: 'Kho chưa có dữ liệu',
      message: 'Thêm vaccine đầu tiên để bắt đầu quản lý tồn kho.',
      actionLabel: 'Thêm vaccine',
      actionHref: '/admin/vaccines/add',
      actionIcon: 'add'
  }) %>
<% } %>

<% if (list.length > 0) { %>
  <div class="v-card !p-0 overflow-hidden animate-fade-in">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
            <th class="px-6 py-4">Vắc xin</th>
            <th class="px-6 py-4">Đơn giá</th>
            <th class="px-6 py-4">Tồn kho</th>
            <th class="px-6 py-4">Trạng thái</th>
            <th class="px-6 py-4 text-center">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline">
          <% list.forEach(v => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="px-6 py-5">
                <p class="font-black text-on-surface uppercase tracking-tight"><%= v.name %></p>
                <p class="text-[10px] font-bold uppercase text-on-surface-variant mt-0.5">ID: #<%= v.id %> • <%= v.ageLabel || (v.recommendedAgeMonths ? 'Từ ' + v.recommendedAgeMonths + ' tháng' : 'Mọi lứa tuổi') %></p>
              </td>
              <td class="px-6 py-5">
                <span class="px-3 py-1 rounded-lg bg-background border border-outline font-black text-sm text-on-surface">
                  <%= new Intl.NumberFormat('vi-VN').format(v.price) %>đ
                </span>
              </td>
              <td class="px-6 py-5">
                <span class="text-2xl font-black tracking-tighter <%= (v.stock || 0) <= 10 ? 'text-error' : 'text-on-surface' %>"><%= v.stock || 0 %></span>
              </td>
              <td class="px-6 py-5">
                <% if ((v.stock || 0) > 10) { %>
                  <span class="v-badge bg-secondary text-white border-transparent">DỒI DÀO</span>
                <% } else if ((v.stock || 0) > 0) { %>
                  <span class="v-badge bg-warning text-white border-transparent">SẮP HẾT</span>
                <% } else { %>
                  <span class="v-badge bg-error text-white border-transparent">HẾT HÀNG</span>
                <% } %>
              </td>
              <td class="px-6 py-5">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/vaccines/edit/<%= v.id %>" class="w-10 h-10 rounded-xl border border-outline bg-white text-on-surface-variant hover:text-primary hover:border-primary flex items-center justify-center transition-all">
                    <span class="material-symbols-outlined text-xl">edit_note</span>
                  </a>
                  <form method="POST" action="/admin/vaccines/delete/<%= v.id %>" class="m-0" onsubmit="return confirm('Xác nhận xóa vắc xin?')">
                    <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                    <button type="submit" class="w-10 h-10 rounded-xl border border-outline bg-white text-on-surface-variant hover:text-error hover:border-error flex items-center justify-center transition-all">
                      <span class="material-symbols-outlined text-xl">delete_forever</span>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%- include('../../partials/pagination', {
      currentPage: currentPage,
      totalPages: totalPages,
      baseUrl: '?page=',
      extraParams: '&search=' + encodeURIComponent(searchVal)
    }) %>
  </div>
<% } %>
