<!-- =====================
  Vaccine Form (Add/Edit)
  Data: vaccine, error, csrfToken
===================== -->

<% const v = vaccine || {}; %>
<% const isEdit = !!v.id; %>

<%- include('../../partials/admin-page-header', {
    title: isEdit ? 'Cập nhật Vaccine' : 'Thêm Vaccine mới',
    subtitle: 'Quản lý thông số kỹ thuật và tồn kho',
    backHref: '/admin/vaccines'
}) %>

<% if (locals.error) { %>
  <div class="mb-6 p-4 rounded-xl bg-error/10 border border-error/20 flex items-center gap-3 shadow-lg animate-shake">
    <span class="material-symbols-outlined text-error text-xl">report</span>
    <p class="text-xs font-black uppercase tracking-tight text-error flex-1"><%= error %></p>
  </div>
<% } %>

<div class="v-card !p-8 max-w-4xl animate-fade-in">
  <form method="POST" action="<%= isEdit ? '/admin/vaccines/edit/' + v.id : '/admin/vaccines/add' %>" class="space-y-8">

    <% if (locals.csrfToken) { %>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <% } %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <div class="md:col-span-2 group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Tên vaccine <span class="text-error">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">vaccines</span>
          <input type="text" name="name" value="<%= v.name || '' %>" required
                 placeholder="VD: Hexaxim"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
        </div>
      </div>

      <div class="md:col-span-2 group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Mô tả</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-5 text-on-surface-variant text-xl">description</span>
          <textarea name="description" rows="4"
                    placeholder="Mô tả công dụng và chỉ định..."
                    class="w-full pl-12 pr-4 py-4 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface resize-none"><%= v.description || '' %></textarea>
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Giá (VNĐ) <span class="text-error">*</span></label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">payments</span>
          <input type="number" name="price" min="0" step="0.01" required value="<%= v.price !== undefined ? v.price : '' %>"
                 placeholder="0"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Tồn kho</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">inventory_2</span>
          <input type="number" name="stock" min="0" value="<%= v.stock !== undefined ? v.stock : 0 %>"
                 placeholder="0"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Độ tuổi khuyến nghị (tháng)</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">cake</span>
          <input type="number" name="recommendedAgeMonths" min="0" value="<%= v.recommendedAgeMonths || '' %>"
                 placeholder="VD: 2"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
        </div>
      </div>

      <div class="group">
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 ml-1">Nhãn độ tuổi</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-xl">label</span>
          <input type="text" name="ageLabel" value="<%= v.ageLabel || '' %>"
                 placeholder="VD: Trẻ từ 2 tháng tuổi"
                 class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm text-on-surface">
        </div>
      </div>

    </div>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" class="v-btn v-btn-primary !px-8 !py-3 !text-[10px] uppercase tracking-widest gap-2">
        <span class="material-symbols-outlined text-sm">save</span>
        <%= isEdit ? 'LƯU CẬP NHẬT' : 'THÊM VACCINE' %>
      </button>
      <a href="/admin/vaccines" class="v-btn v-btn-secondary !px-8 !py-3 !text-[10px] uppercase tracking-widest">HỦY</a>
    </div>

  </form>
</div>
