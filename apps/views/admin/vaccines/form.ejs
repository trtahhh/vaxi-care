<%- include('../layout', { 
    title: (locals.editingVaccine ? 'Sửa' : 'Thêm') + ' Vaccine - VaxiCare',
    body: `

<!-- Page Header -->
<div class="flex items-center gap-4 mb-8 animate-fade-in">
    <a href="/admin/vaccines" class="w-10 h-10 flex items-center justify-center rounded-lg bg-surface border border-outline text-on-surface-variant hover:text-primary transition-all shadow-sm">
        <span class="material-symbols-outlined">arrow_back</span>
    </a>
    <div>
        <h1 class="text-3xl v-title tracking-tight uppercase"><%= locals.editingVaccine ? 'Cập nhật' : 'Nhập kho' %> Vaccine</h1>
        <p class="text-on-surface-variant text-sm font-medium">Quản lý thông số kỹ thuật và số lượng tồn kho vaccine.</p>
    </div>
</div>

<div class="v-card !p-8 md:!p-10 max-w-4xl animate-fade-in" style="animation-delay: 0.1s">
    <form method="POST" action="<%= locals.editingVaccine ? '/admin/vaccines/edit/' + editingVaccine.id : '/admin/vaccines/add' %>" class="space-y-8">
        <% if (locals.csrfToken) { %>
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Vaccine Name -->
            <div class="md:col-span-2 group">
                <label class="v-subtitle mb-2 block ml-1">Tên Vaccine <span class="text-error font-black ml-1">*</span></label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">vaccines</span>
                    <input type="text" name="name" value="<%= locals.editingVaccine ? editingVaccine.name : '' %>" required
                           placeholder="VD: VNVC 6 trong 1"
                           class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm">
                </div>
            </div>

            <!-- Description -->
            <div class="md:col-span-2 group">
                <label class="v-subtitle mb-2 block ml-1">Mô tả & Công dụng</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-6 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">description</span>
                    <textarea name="description" rows="4" 
                              placeholder="Mô tả chi tiết về liều lượng, công dụng..."
                              class="w-full pl-12 pr-4 py-4 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm min-h-[120px]"><%= locals.editingVaccine ? (editingVaccine.description || '') : '' %></textarea>
                </div>
            </div>

            <!-- Price -->
            <div class="group">
                <label class="v-subtitle mb-2 block ml-1">Đơn giá (VNĐ) <span class="text-error font-black ml-1">*</span></label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">payments</span>
                    <input type="number" name="price" value="<%= locals.editingVaccine ? editingVaccine.price : '' %>" step="0.01" min="0" required
                           placeholder="0.00"
                           class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm">
                </div>
            </div>

            <!-- Stock -->
            <div class="group">
                <label class="v-subtitle mb-2 block ml-1">Số lượng tồn kho</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">inventory_2</span>
                    <input type="number" name="stock" value="<%= locals.editingVaccine ? editingVaccine.stock : 0 %>" min="0"
                           placeholder="0"
                           class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm">
                </div>
            </div>

            <!-- Recommended Age -->
            <div class="group">
                <label class="v-subtitle mb-2 block ml-1">Độ tuổi khuyến nghị (tháng)</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">cake</span>
                    <input type="number" name="recommendedAgeMonths" value="<%= locals.editingVaccine && editingVaccine.recommendedAgeMonths ? editingVaccine.recommendedAgeMonths : '' %>" min="0"
                           placeholder="VD: 2"
                           class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm">
                </div>
            </div>

            <!-- Age Label -->
            <div class="group">
                <label class="v-subtitle mb-2 block ml-1">Nhãn hiển thị (VD: 2 tháng tuổi)</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">label</span>
                    <input type="text" name="ageLabel" value="<%= locals.editingVaccine ? (editingVaccine.ageLabel || '') : '' %>"
                           placeholder="VD: Trẻ từ 2 tháng tuổi"
                           class="w-full pl-12 pr-4 py-3.5 bg-background border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary transition-all font-bold text-sm">
                </div>
            </div>
        </div>

        <div class="flex items-center gap-4 pt-4">
            <button type="submit" class="v-btn v-btn-primary !px-10 uppercase !text-xs tracking-widest gap-2">
                <span class="material-symbols-outlined text-[18px]">save_as</span>
                <%= locals.editingVaccine ? 'Cập nhật' : 'Nhập kho vaccine' %>
            </button>
            <a href="/admin/vaccines" class="v-btn v-btn-secondary !px-10 uppercase !text-xs tracking-widest">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>

` }) %>