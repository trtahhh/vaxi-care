<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Admin - VaxiCare' %></title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/style.css">
    <script id="tailwind-config">
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              "primary": "#3182CE",
              "secondary": "#2F855A",
              "background": "#F8FAFC",
              "surface": "#FFFFFF",
              "on-surface": "#1A202C",
              "on-surface-variant": "#64748B",
              "outline": "#E2E8F0",
              "error": "#E53E3E",
              "warning": "#DD6B20"
            },
            fontFamily: {
              "headline": ["Inter", "sans-serif"],
              "body": ["Inter", "sans-serif"]
            }
          }
        }
      }
    </script>
    <style>
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        body { background-color: #F8FAFC; font-family: 'Inter', sans-serif; color: #1A202C; }
        
        /* Clean Solid Styles */
        .card { background: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 0.75rem; padding: 1.5rem; margin-bottom: 1.5rem; }
        .btn-primary { background: #3182CE; color: #FFFFFF; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-weight: 600; transition: background 0.2s; }
        .btn-primary:hover { background: #2C5282; }
        
        .table { width: 100%; border-collapse: collapse; }
        .table th { border-bottom: 2px solid #E2E8F0; padding: 1rem; color: #4A5568; font-weight: 600; }
        .table td { border-bottom: 1px solid #E2E8F0; padding: 1rem; color: #2D3748; }
        
        .form-control { background: #FFFFFF; border: 1px solid #E2E8F0; color: #1A202C; padding: 0.625rem; border-radius: 0.5rem; width: 100%; }
        .form-control:focus { outline: none; border-color: #3182CE; }
    </style>
    <%- typeof extraCss !== 'undefined' ? extraCss : '' %>
</head>
<body class="min-h-screen">

    <!-- Top Navigation -->
    <header class="fixed top-0 w-full z-50 bg-[#060e20]/80 backdrop-blur-3xl shadow-[0_32px_64px_rgba(59,130,246,0.06)] border-b border-outline-variant/20">
        <div class="flex justify-between items-center px-6 h-16 w-full max-w-7xl mx-auto">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center border border-outline-variant/20">
                    <span class="material-symbols-outlined text-primary text-xl">admin_panel_settings</span>
                </div>
                <h1 class="text-xl font-extrabold text-[#85adff] font-headline tracking-tight">VaxiCare</h1>
            </div>
            
            <nav class="hidden md:flex items-center gap-6 text-sm font-bold tracking-wide uppercase text-on-surface-variant">
                <a href="/admin/dashboard" class="hover:text-primary transition-colors">Tổng quan</a>
                <a href="/admin/vaccines" class="hover:text-primary transition-colors">Kho Vaccine</a>
                <a href="/admin/schedule" class="hover:text-primary transition-colors">Lịch Hẹn</a>
                <a href="/admin/children" class="hover:text-primary transition-colors">Hồ sơ trẻ</a>
                <a href="/admin/users" class="hover:text-primary transition-colors">Nhân Sự</a>
            </nav>

            <div class="flex items-center gap-4">
                <span class="text-sm font-medium text-on-surface hidden md:block">
                    <%= locals.user ? user.username : 'Admin Staff' %>
                </span>
                <form action="/auth/logout" method="POST" class="m-0 cursor-pointer">
                    <button type="submit" class="w-10 h-10 flex items-center justify-center rounded-full bg-surface-container-high hover:bg-error/20 hover:text-error transition-colors active:scale-95 duration-200 text-[#dee5ff]">
                        <span class="material-symbols-outlined text-[20px]">logout</span>
                    </button>
                </form>
            </div>
        </div>
    </header>

    <main class="pt-24 pb-12 px-6 max-w-7xl mx-auto space-y-10">
        <%- body %>
    </main>

    <!-- Mobile Bottom Navigation Fallback -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 bg-[#060e20]/90 backdrop-blur-3xl rounded-t-3xl border-t border-outline-variant/20">
        <div class="flex justify-around items-center px-4 pb-6 pt-3">
            <a href="/admin/dashboard" class="flex flex-col items-center justify-center text-[#dee5ff]/60 px-4 py-1.5 hover:text-[#85adff] transition-all">
                <span class="material-symbols-outlined text-xl">dashboard</span>
                <span class="font-headline text-[10px] font-bold uppercase tracking-widest mt-1">Tổng quan</span>
            </a>
            <a href="/admin/schedule" class="flex flex-col items-center justify-center text-[#dee5ff]/60 px-4 py-1.5 hover:text-[#85adff] transition-all">
                <span class="material-symbols-outlined text-xl">event_available</span>
                <span class="font-headline text-[10px] font-bold uppercase tracking-widest mt-1">Lịch Hẹn</span>
            </a>
            <a href="/admin/children" class="flex flex-col items-center justify-center text-[#dee5ff]/60 px-4 py-1.5 hover:text-[#85adff] transition-all">
                <span class="material-symbols-outlined text-xl">child_care</span>
                <span class="font-headline text-[10px] font-bold uppercase tracking-widest mt-1">Hồ sơ trẻ</span>
            </a>
            <a href="/admin/vaccines" class="flex flex-col items-center justify-center text-[#dee5ff]/60 px-4 py-1.5 hover:text-[#85adff] transition-all">
                <span class="material-symbols-outlined text-xl">inventory_2</span>
                <span class="font-headline text-[10px] font-bold uppercase tracking-widest mt-1">Kho thuốc</span>
            </a>
        </div>
    </nav>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize progress bars
            document.querySelectorAll('.js-progress-bar').forEach(el => {
                if (el.dataset.width) el.style.width = el.dataset.width;
            });

            // Initialize animation delays
            document.querySelectorAll('.js-delay-init').forEach(el => {
                if (el.dataset.delay) el.style.animationDelay = el.dataset.delay;
            });
        });
    </script>
    <%- typeof extraJs !== 'undefined' ? extraJs : '' %>
</body>
</html>