<!-- =====================
  Pending Appointments
  Data: appointments[], currentPage, totalPages
===================== -->

<%- include('../../partials/admin-page-header', {
    title: 'Duyệt lịch hẹn',
    subtitle: 'Xử lý các yêu cầu đặt lịch tiêm đang chờ duyệt',
    backHref: '/admin/dashboard',
    badge: (appointments || []).length + ' chờ duyệt',
    badgeVariant: 'warning'
}) %>

<% const list = appointments || []; %>

<%# Empty state %>
<% if (list.length === 0) { %>
  <%- include('../../partials/empty-state', {
      icon: 'task_alt',
      title: 'Không có yêu cầu chờ duyệt',
      message: 'Hiện tại hệ thống không có lịch hẹn nào cần xử lý.'
  }) %>
<% } %>

<%# Table %>
<% if (list.length > 0) { %>
  <div class="v-card !p-0 overflow-hidden animate-fade-in">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
            <th class="p-5">Bé</th>
            <th class="p-5">Vắc xin</th>
            <th class="p-5">Thời gian</th>
            <th class="p-5">Trạng thái</th>
            <th class="p-5 text-center">Xử lý</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline">
          <% list.forEach(app => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="p-5">
                <p class="font-black text-sm uppercase tracking-tight text-on-surface"><%= app.child && app.child.name ? app.child.name : 'N/A' %></p>
                <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mt-0.5">
                  PH: <%= app.child && app.child.parent ? (app.child.parent.fullName || app.child.parent.username) : 'N/A' %>
                </p>
              </td>
              <td class="p-5">
                <p class="font-black text-sm uppercase tracking-tight text-primary"><%= app.vaccine && app.vaccine.name ? app.vaccine.name : 'Vắc xin' %></p>
                <p class="text-[10px] font-bold uppercase text-on-surface-variant"><%= app.vaccine && app.vaccine.type ? app.vaccine.type : '' %></p>
              </td>
              <td class="p-5">
                <p class="font-black text-sm uppercase text-on-surface"><%= app.date ? new Date(app.date).toLocaleDateString('vi-VN') : '' %></p>
                <p class="text-[10px] font-bold uppercase text-on-surface-variant"><%= app.appointmentTime || '--:--' %></p>
              </td>
              <td class="p-5">
                <%- include('../../partials/status-badge', { status: app.status || 'pending' }) %>
              </td>
              <td class="p-5">
                <div class="flex items-center justify-center gap-2">
                  <form action="/admin/appointments/<%= app.id %>/status" method="POST" class="m-0">
                    <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                    <input type="hidden" name="status" value="confirmed">
                    <button type="submit" class="v-btn v-btn-primary !py-2 !px-4 !text-[10px] gap-1.5">
                      <span class="material-symbols-outlined text-sm">check</span>
                      DUYỆT
                    </button>
                  </form>
                  <form action="/admin/appointments/<%= app.id %>/status" method="POST" class="m-0">
                    <% if (locals.csrfToken) { %><input type="hidden" name="_csrf" value="<%= csrfToken %>"><% } %>
                    <input type="hidden" name="status" value="cancelled">
                    <button type="submit" class="v-btn v-btn-secondary !bg-error/5 !text-error !border-error/20 !py-2 !px-4 !text-[10px] gap-1.5">
                      <span class="material-symbols-outlined text-sm">close</span>
                      TỪ CHỐI
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%- include('../../partials/pagination', {
        currentPage: currentPage,
        totalPages: totalPages,
        baseUrl: '?page=',
        extraParams: ''
    }) %>
  </div>
<% } %>
