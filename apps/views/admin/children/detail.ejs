<!-- =====================
  Admin Child Detail
  Data: child, appointments[]
===================== -->

<% if (!locals.child) { %>
  <%- include('../../partials/empty-state', {
      icon: 'child_care',
      title: 'Không tìm thấy hồ sơ trẻ',
      message: 'Vui lòng quay lại danh sách để kiểm tra.',
      actionLabel: 'Quay lại danh sách',
      actionHref: '/admin/children'
  }) %>
  <% return; %>
<% } %>

<%- include('../../partials/admin-page-header', {
    title: 'Chi tiết hồ sơ: ' + child.name,
    subtitle: 'Thông tin trẻ và lịch sử tiêm chủng',
    backHref: '/admin/children',
    actions: [ { label: 'Đặt lịch tiêm', href: '/appointments/book?childId=' + child.id, icon: 'event_available', variant: 'primary' } ]
}) %>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-fade-in">

  <%# Left column — profile %>
  <div class="lg:col-span-1">
    <div class="v-card !p-8 sticky top-24">
      <div class="text-center mb-8 pb-8 border-b border-outline">
        <div class="w-24 h-24 rounded-2xl mx-auto mb-5 flex items-center justify-center text-white shadow-lg
            <%= child.gender === 'male' ? 'bg-primary' : 'bg-error' %>">
          <span class="material-symbols-outlined text-5xl"><%= child.gender === 'male' ? 'boy' : 'girl' %></span>
        </div>
        <h2 class="text-3xl font-display font-black uppercase tracking-tight text-on-surface leading-none mt-2"><%= child.name %></h2>
        <span class="v-badge mt-3 <%= child.gender === 'male' ? 'bg-primary/10 text-primary border-primary/20' : 'bg-error/10 text-error border-error/20' %>">
          <%= child.gender === 'male' ? 'NAM' : 'NỮ' %>
        </span>
      </div>

      <div class="space-y-4">
        <div class="p-4 rounded-xl bg-background border border-outline">
          <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Ngày sinh</p>
          <p class="text-sm font-black text-on-surface"><%= child.dob ? new Date(child.dob).toLocaleDateString('vi-VN') : '-' %></p>
        </div>

        <div class="p-4 rounded-xl bg-background border border-outline">
          <p class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Phụ huynh quản lý</p>
          <% if (child.parent) { %>
            <p class="text-sm font-black uppercase tracking-tight text-on-surface"><%= child.parent.fullName || child.parent.username %></p>
            <p class="text-[10px] font-bold text-on-surface-variant mt-1"><%= child.parent.phone || child.parent.email || '' %></p>
          <% } else { %>
            <p class="text-xs font-black uppercase text-error">Chưa gán phụ huynh</p>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <%# Right column — appointments %>
  <div class="lg:col-span-2">
    <div class="v-card !p-0 overflow-hidden">
      <div class="px-8 py-6 border-b border-outline/50 bg-background/50 flex items-center justify-between">
        <h3 class="text-xl font-display font-black uppercase tracking-tight text-on-surface">Lịch sử tiêm chủng</h3>
        <span class="v-badge bg-primary/10 text-primary border-primary/20"><%= (appointments || []).length %> bản ghi</span>
      </div>

      <% if ((appointments || []).length === 0) { %>
        <div class="p-16 text-center opacity-60">
          <span class="material-symbols-outlined text-4xl text-on-surface-variant mb-3 block">event_busy</span>
          <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Chưa có lịch sử tiêm</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
                <th class="p-5">Thời gian</th>
                <th class="p-5">Vắc xin</th>
                <th class="p-5">Trạng thái</th>
                <th class="p-5">Ghi chú</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-outline">
              <% appointments.forEach(a => { %>
                <tr class="hover:bg-primary/5 transition-colors">
                  <td class="p-5">
                    <p class="font-black text-sm uppercase text-on-surface"><%= new Date(a.date).toLocaleDateString('vi-VN') %></p>
                    <p class="text-[10px] font-bold uppercase text-on-surface-variant mt-0.5"><%= a.appointmentTime || '--:--' %></p>
                  </td>
                  <td class="p-5">
                    <p class="font-black text-sm uppercase tracking-tight text-on-surface"><%= a.vaccine && a.vaccine.name ? a.vaccine.name : 'Vắc xin' %></p>
                  </td>
                  <td class="p-5">
                    <%- include('../../partials/status-badge', { status: a.status }) %>
                  </td>
                  <td class="p-5 text-xs font-medium text-on-surface-variant italic"><%= a.notes || 'Không có ghi chú' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>

</div>
