<%- include('../layout', { body: `
<div class="page-header">
    <h1 class="page-title"><i class="bi bi-heart"></i> Quản lý Trẻ em</h1>
</div>

<div class="card">
    <div class="toolbar">
        <form class="search-box" method="GET" action="/admin/children">
            <input type="text" name="search" class="form-control" placeholder="Tìm kiếm theo tên..." value="${search}">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> Tìm
            </button>
            ${search ? '<a href="/admin/children" class="btn btn-secondary"><i class="bi bi-x-circle"></i> Xóa</a>' : ''}
        </form>
    </div>

    ${children.length > 0 ? `
    <div class="table-wrapper">
        <table class="table">
            <thead>
                <tr>
                    <th><i class="bi bi-hash"></i> ID</th>
                    <th><i class="bi bi-person"></i> Tên trẻ</th>
                    <th><i class="bi bi-cake"></i> Ngày sinh</th>
                    <th><i class="bi bi-gender"></i> Giới tính</th>
                    <th><i class="bi bi-people"></i> Phụ huynh</th>
                    <th><i class="bi bi-gear"></i> Thao tác</th>
                </tr>
            </thead>
            <tbody>
                ${children.map(c => `
                <tr>
                    <td><strong>${c.id}</strong></td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <i class="bi bi-${c.gender === 'male' ? 'gender-male' : c.gender === 'female' ? 'gender-female' : 'gender-ambiguous'}" style="color: ${c.gender === 'male' ? '#3498db' : c.gender === 'female' ? '#e91e63' : '#9b59b6'}"></i>
                            ${c.name}
                        </div>
                    </td>
                    <td>${c.dob ? new Date(c.dob).toLocaleDateString('vi-VN') : '-'}</td>
                    <td>
                        <span style="color: ${c.gender === 'male' ? '#3498db' : c.gender === 'female' ? '#e91e63' : '#9b59b6'}">
                            ${c.gender === 'male' ? '<i class="bi bi-gender-male"></i> Nam' : c.gender === 'female' ? '<i class="bi bi-gender-female"></i> Nữ' : '<i class="bi bi-gender-ambiguous"></i> Khác'}
                        </span>
                    </td>
                    <td>
                        ${c.parent ? \`<a href="mailto:\${c.parent.email}" style="display: flex; align-items: center; gap: 5px; color: #3498db; text-decoration: none;"><i class="bi bi-person"></i> \${c.parent.fullName || c.parent.username}</a>\` : '-'}
                    </td>
                    <td>
                        <a href="/admin/children/${c.id}" class="btn btn-primary btn-sm">
                            <i class="bi bi-eye"></i> Xem chi tiết
                        </a>
                    </td>
                </tr>
                `).join('')}
            </tbody>
        </table>
    </div>

    ${totalPages > 1 ? `
    <div class="pagination">
        ${currentPage > 1 ? \`<a href="?page=\${currentPage - 1}&search=\${search}"><i class="bi bi-chevron-left"></i> Trước</a>\` : '<span class="disabled"><i class="bi bi-chevron-left"></i> Trước</span>'}
        ${Array.from({length: totalPages}, (_, i) => \`
            <a href="?page=\${i + 1}&search=\${search}" class="\${currentPage === i + 1 ? 'active' : ''}">\${i + 1}</a>
        \`).join('')}
        ${currentPage < totalPages ? \`<a href="?page=\${currentPage + 1}&search=\${search}">Sau <i class="bi bi-chevron-right"></i></a>\` : '<span class="disabled">Sau <i class="bi bi-chevron-right"></i></span>'}
    </div>
    ` : ''}
    ` : `
    <div class="empty-state">
        <i class="bi bi-heart"></i>
        <p>Không có trẻ em nào</p>
    </div>
    `}
</div>

<script>
    // Show toast if redirected with message
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('success')) {
        showToast('success', 'Thành công', decodeURIComponent(urlParams.get('success')));
    }
    if (urlParams.get('error')) {
        showToast('error', 'Lỗi', decodeURIComponent(urlParams.get('error')));
    }
</script>
` }) %>