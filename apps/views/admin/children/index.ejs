<!-- =====================
  Admin Children Index
  Data: children[], search, currentPage, totalPages
===================== -->

<% const list = children || []; %>
<% const searchVal = search || ''; %>

<%- include('../../partials/admin-page-header', {
    title: 'Quản lý hồ sơ trẻ',
    subtitle: 'Theo dõi toàn bộ hồ sơ trẻ em trong hệ thống',
    actions: [ { label: 'Lập hồ sơ mới', href: '/children/add', icon: 'add_circle', variant: 'primary' } ]
}) %>

<%- include('../../partials/admin-filter-bar', {
    action: '/admin/children',
    searchValue: searchVal,
    searchPlaceholder: 'Tìm tên trẻ...',
    clearHref: '/admin/children'
}) %>

<% if (list.length === 0) { %>
  <%- include('../../partials/empty-state', {
      icon: 'person_search',
      title: 'Không tìm thấy hồ sơ trẻ',
      message: 'Thử lại với từ khóa khác hoặc thêm hồ sơ mới.'
  }) %>
<% } %>

<% if (list.length > 0) { %>
  <div class="v-card !p-0 overflow-hidden animate-fade-in">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-background text-on-surface-variant text-[10px] font-black uppercase tracking-widest border-b border-outline">
            <th class="p-5">Trẻ</th>
            <th class="p-5">Ngày sinh</th>
            <th class="p-5">Giới tính</th>
            <th class="p-5">Phụ huynh</th>
            <th class="p-5 text-center">Thao tác</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-outline">
          <% list.forEach(c => { %>
            <tr class="hover:bg-primary/5 transition-colors">
              <td class="p-5">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-xl <%= c.gender === 'male' ? 'bg-primary text-white' : 'bg-error text-white' %> flex items-center justify-center shadow-sm">
                    <span class="material-symbols-outlined text-xl"><%= c.gender === 'male' ? 'boy' : 'girl' %></span>
                  </div>
                  <div>
                    <p class="font-black text-sm uppercase tracking-tight text-on-surface"><%= c.name %></p>
                    <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest mt-0.5">ID: #<%= c.id %></p>
                  </div>
                </div>
              </td>
              <td class="p-5 text-sm font-bold text-on-surface-variant"><%= c.dob ? new Date(c.dob).toLocaleDateString('vi-VN') : '-' %></td>
              <td class="p-5">
                <span class="v-badge <%= c.gender === 'male' ? 'bg-primary/10 text-primary border-primary/20' : 'bg-error/10 text-error border-error/20' %>">
                  <%= c.gender === 'male' ? 'NAM' : 'NỮ' %>
                </span>
              </td>
              <td class="p-5">
                <% if (c.parent) { %>
                  <p class="font-black text-sm uppercase tracking-tight text-on-surface"><%= c.parent.fullName || c.parent.username %></p>
                  <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest mt-0.5"><%= c.parent.phone || c.parent.email || '' %></p>
                <% } else { %>
                  <span class="text-xs font-black uppercase text-error/70 tracking-widest">Chưa gán PH</span>
                <% } %>
              </td>
              <td class="p-5">
                <div class="flex items-center justify-center gap-2">
                  <a href="/admin/children/<%= c.id %>" class="w-9 h-9 rounded-lg border border-outline text-primary bg-white hover:bg-primary hover:text-white flex items-center justify-center transition-all" title="Xem chi tiết">
                    <span class="material-symbols-outlined text-lg">visibility</span>
                  </a>
                  <a href="/appointments/book?childId=<%= c.id %>" class="w-9 h-9 rounded-lg border border-outline text-secondary bg-white hover:bg-secondary hover:text-white flex items-center justify-center transition-all" title="Đặt lịch tiêm">
                    <span class="material-symbols-outlined text-lg">event_available</span>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <%- include('../../partials/pagination', {
      currentPage: currentPage,
      totalPages: totalPages,
      baseUrl: '?page=',
      extraParams: '&search=' + encodeURIComponent(searchVal)
    }) %>
  </div>
<% } %>
