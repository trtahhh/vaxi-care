<!-- =====================
  Admin Dashboard
  Data: userCount, childCount, vaccineCount, todayAppointments, weeklyTrend, stockAlerts
===================== -->

<%- include('../partials/admin-page-header', {
    title: 'Tổng quan quản trị',
    subtitle: 'Giám sát nhanh toàn bộ hệ thống VaxiCare',
    actions: [
      { label: 'Duyệt lịch hẹn', href: '/admin/appointments/pending', icon: 'pending_actions', variant: 'secondary' }
    ]
}) %>

<div class="space-y-8 animate-fade-in">

  <%# Stats cards %>
  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
    <%- include('../partials/stat-card', { icon: 'event_available', label: 'Lịch tiêm hôm nay', value: todayAppointments || 0, iconColor: 'text-primary' }) %>
    <%- include('../partials/stat-card', { icon: 'child_care', label: 'Hồ sơ trẻ', value: childCount || 0, iconColor: 'text-secondary' }) %>
    <%- include('../partials/stat-card', { icon: 'vaccines', label: 'Loại vắc xin', value: vaccineCount || 0, iconColor: 'text-warning' }) %>
    <%- include('../partials/stat-card', { icon: 'group', label: 'Người dùng', value: userCount || 0, iconColor: 'text-error' }) %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Weekly trend chart %>
    <div class="lg:col-span-2 v-card !p-6">
      <div class="flex items-center justify-between mb-5">
        <h3 class="text-xl font-display font-black tracking-tight text-on-surface flex items-center gap-2 leading-none">
          <span class="material-symbols-outlined text-primary text-2xl">trending_up</span>
          Xu hướng lịch hẹn (7 ngày)
        </h3>
      </div>
      <div id="trendChartContainer" class="h-[300px]" data-trend='<%- JSON.stringify(weeklyTrend || []) %>'>
        <canvas id="trendChart"></canvas>
      </div>
    </div>

    <%# Stock alerts %>
    <div class="v-card !p-6">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-xl font-display font-black tracking-tight text-on-surface flex items-center gap-2 leading-none">
          <span class="material-symbols-outlined text-error text-2xl">inventory_2</span>
          Cảnh báo kho
        </h3>
        <a href="/admin/vaccines" class="text-[10px] font-black text-primary uppercase tracking-widest">Xem tất cả</a>
      </div>

      <% const alerts = stockAlerts || []; %>
      <% if (alerts.length === 0) { %>
        <div class="py-8 text-center opacity-50">
          <span class="material-symbols-outlined text-4xl text-secondary mb-2 block">check_circle</span>
          <p class="text-xs font-black uppercase tracking-widest text-on-surface-variant">Kho ổn định</p>
        </div>
      <% } else { %>
        <div class="space-y-3 max-h-[280px] overflow-y-auto custom-scrollbar pr-1">
          <% alerts.forEach(v => { %>
            <div class="p-3 bg-background rounded-xl border border-outline flex items-center justify-between gap-3 hover:border-error/30 transition-colors">
              <div class="min-w-0">
                <p class="font-black text-sm text-on-surface truncate"><%= v.name %></p>
                <p class="text-[10px] font-bold uppercase text-on-surface-variant tracking-widest"><%= v.type || 'Vaccine' %></p>
              </div>
              <span class="v-badge bg-error/10 text-error border-error/20"><%= v.stock %> còn</span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('trendChartContainer');
    if (!container) return;
    const trend = JSON.parse(container.dataset.trend || '[]');
    if (!trend || trend.length === 0) return;
    const ctx = document.getElementById('trendChart').getContext('2d');

    new Chart(ctx, {
      type: 'line',
      data: {
        labels: trend.map(i => i.date),
        datasets: [{
          label: 'Lịch hẹn',
          data: trend.map(i => i.count),
          borderColor: '#3182CE',
          backgroundColor: 'rgba(49,130,206,0.1)',
          borderWidth: 3,
          tension: 0.35,
          fill: true,
          pointBackgroundColor: '#fff',
          pointBorderColor: '#3182CE',
          pointRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: { beginAtZero: true, grid: { color: '#E2E8F0' } },
          x: { grid: { display: false } }
        }
      }
    });
  });
</script>
