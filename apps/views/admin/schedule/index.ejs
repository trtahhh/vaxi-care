<!-- =====================
  Admin Schedule Config
  Data: daysInMonth[], currentMonth, currentYear
===================== -->

<%- include('../../partials/admin-page-header', {
    title: 'Quản lý lịch tiêm',
    subtitle: 'Thiết lập slot theo ngày & buổi'
}) %>

<!-- Flash messages -->
<% if (error) { %>
<div class="mb-6 px-4 py-3 rounded-xl bg-error/10 border border-error/30 text-error text-sm font-medium flex items-center gap-2">
  <span class="material-symbols-outlined text-error text-lg">error</span> <%= error %>
</div>
<% } %>
<% if (success) { %>
<div class="mb-6 px-4 py-3 rounded-xl bg-success/10 border border-success/30 text-success text-sm font-medium flex items-center gap-2">
  <span class="material-symbols-outlined text-success text-lg">check_circle</span> <%= success %>
</div>
<% } %>

<div class="v-card !p-6 animate-fade-in space-y-6">

  <%# Month navigation %>
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 pb-6 border-b border-outline">
    <div class="flex items-center gap-3 p-2 rounded-xl bg-background border border-outline">
      <a href="?month=<%= currentMonth === 1 ? 12 : currentMonth - 1 %>&year=<%= currentMonth === 1 ? currentYear - 1 : currentYear %>"
         class="w-10 h-10 rounded-lg border border-outline bg-white text-on-surface-variant hover:text-primary flex items-center justify-center transition-all">
        <span class="material-symbols-outlined">chevron_left</span>
      </a>
      <span class="px-5 text-3xl font-display font-black uppercase tracking-tight text-on-surface leading-none mt-1">THÁNG <%= currentMonth %> / <%= currentYear %></span>
      <a href="?month=<%= currentMonth === 12 ? 1 : currentMonth + 1 %>&year=<%= currentMonth === 12 ? currentYear + 1 : currentYear %>"
         class="w-10 h-10 rounded-lg border border-outline bg-white text-on-surface-variant hover:text-primary flex items-center justify-center transition-all">
        <span class="material-symbols-outlined">chevron_right</span>
      </a>
    </div>

    <div class="flex items-center gap-5 text-[10px] font-black uppercase tracking-widest text-on-surface-variant">
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-secondary"></span>Có cấu hình</div>
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-warning"></span>Mặc định</div>
      <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-error/50"></span>Ngày nghỉ</div>
    </div>
  </div>

  <%# Legend & Bulk Config %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <%# Bulk Config Form %>
    <div class="rounded-xl border border-outline bg-background p-4">
      <h4 class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">bolt</span>
        Cấu hình hàng loạt (ngày trong tuần)
      </h4>
      <form method="POST" action="/admin/schedule/bulk-update" class="grid grid-cols-3 gap-2">
        <% if (typeof csrfToken !== 'undefined') { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
        <input type="hidden" name="month" value="<%= currentMonth %>">
        <input type="hidden" name="year" value="<%= currentYear %>">

        <div>
          <label class="block text-[9px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Tổng slot</label>
          <input type="number" name="maxSlots" value="50" min="0" max="1000" required
                 class="w-full px-3 py-2 bg-white border border-outline rounded-lg text-xs font-bold text-on-surface focus:outline-none focus:border-primary">
        </div>
        <div>
          <label class="block text-[9px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Sáng</label>
          <input type="number" name="morningSlots" value="25" min="0" max="1000" required
                 class="w-full px-3 py-2 bg-white border border-outline rounded-lg text-xs font-bold text-on-surface focus:outline-none focus:border-primary">
        </div>
        <div>
          <label class="block text-[9px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Chiều</label>
          <input type="number" name="afternoonSlots" value="25" min="0" max="1000" required
                 class="w-full px-3 py-2 bg-white border border-outline rounded-lg text-xs font-bold text-on-surface focus:outline-none focus:border-primary">
        </div>
        <div class="col-span-3">
          <label class="block text-[9px] font-black uppercase tracking-widest text-on-surface-variant mb-1">Ghi chú</label>
          <input type="text" name="note" placeholder="VD: Ngày lễ, cấu hình mặc định..." maxlength="255"
                 class="w-full px-3 py-2 bg-white border border-outline rounded-lg text-xs font-bold text-on-surface focus:outline-none focus:border-primary">
        </div>
        <div class="col-span-3 flex items-center gap-2">
          <input type="checkbox" name="isDayOff" id="bulk-dayoff" value="1"
                 class="accent-primary w-4 h-4">
          <label for="bulk-dayoff" class="text-[9px] font-bold text-error uppercase tracking-widest">Đánh dấu ngày nghỉ</label>
        </div>
        <button type="submit" class="col-span-3 v-btn v-btn-primary !py-2 !text-[9px] uppercase tracking-widest">
          Áp dụng cho tất cả ngày trong tuần
        </button>
      </form>
    </div>

    <%# Quick Stats %>
    <div class="rounded-xl border border-outline bg-background p-4">
      <h4 class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-3 flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">insights</span>
        Tổng quan tháng
      </h4>
      <%
        const totalSlots = (daysInMonth || []).filter(d => !d.isPast && !d.isWeekend).reduce((sum, d) => sum + d.maxSlots, 0);
        const totalBooked = (daysInMonth || []).filter(d => !d.isPast).reduce((sum, d) => sum + d.bookedCount, 0);
        const configCount = (daysInMonth || []).filter(d => d.hasConfig && !d.isPast).length;
        const totalDays = (daysInMonth || []).filter(d => !d.isPast && !d.isWeekend).length;
      %>
      <div class="grid grid-cols-2 gap-3">
        <div class="bg-white rounded-lg border border-outline p-3 text-center">
          <div class="text-2xl font-black text-primary"><%= totalDays %></div>
          <div class="text-[9px] font-bold uppercase tracking-widest text-on-surface-variant">Ngày làm việc</div>
        </div>
        <div class="bg-white rounded-lg border border-outline p-3 text-center">
          <div class="text-2xl font-black text-primary"><%= totalSlots %></div>
          <div class="text-[9px] font-bold uppercase tracking-widest text-on-surface-variant">Tổng slot</div>
        </div>
        <div class="bg-white rounded-lg border border-outline p-3 text-center">
          <div class="text-2xl font-black text-warning"><%= totalBooked %></div>
          <div class="text-[9px] font-bold uppercase tracking-widest text-on-surface-variant">Đã đặt</div>
        </div>
        <div class="bg-white rounded-lg border border-outline p-3 text-center">
          <div class="text-2xl font-black text-success"><%= totalSlots - totalBooked %></div>
          <div class="text-[9px] font-bold uppercase tracking-widest text-on-surface-variant">Còn trống</div>
        </div>
      </div>
    </div>
  </div>

  <%# Calendar grid %>
  <div class="grid grid-cols-7 gap-3">
    <% ['CN','T2','T3','T4','T5','T6','T7'].forEach(d => { %>
      <div class="text-center pb-2 text-[10px] font-black uppercase tracking-widest <%= d === 'CN' ? 'text-error' : 'text-on-surface-variant' %>"><%= d %></div>
    <% }) %>

    <% (daysInMonth || []).forEach(d => { %>
      <div class="min-h-[160px] rounded-xl border-2 p-3 transition-all flex flex-col gap-1
          <%= d.empty ? 'border-transparent' : 'border-outline bg-background hover:border-primary/40' %>
          <%= d.today ? 'border-primary bg-primary/5' : '' %>
          <%= d.isPast ? 'opacity-40' : '' %>
          <%= d.isWeekend && !d.empty ? 'bg-error/5 border-error/20' : '' %>
          <%= d.isDayOff && !d.empty && !d.isPast ? 'bg-error/5 border-error/30' : '' %>">
        <% if (!d.empty) { %>
          <%# Header %>
          <div class="flex justify-between items-start mb-2">
            <span class="text-lg font-black <%= d.today ? 'text-primary' : d.isWeekend ? 'text-error' : 'text-on-surface' %>"><%= d.day %></span>
            <% if (d.isWeekend) { %>
              <span class="text-[8px] font-black uppercase tracking-widest text-error px-1.5 py-0.5 rounded bg-error/10">CT</span>
            <% } else if (d.isDayOff) { %>
              <span class="text-[8px] font-black uppercase tracking-widest text-error px-1.5 py-0.5 rounded bg-error/10">Nghỉ</span>
            <% } else if (d.hasConfig) { %>
              <span class="w-2 h-2 rounded-full bg-secondary mt-1"></span>
            <% } else if (!d.isPast) { %>
              <span class="w-2 h-2 rounded-full bg-warning mt-1"></span>
            <% } %>
          </div>

          <%# Slot info %>
          <% if (!d.isWeekend && !d.isDayOff) { %>
            <div class="space-y-0.5 text-[8px]">
              <div class="flex justify-between font-bold text-primary">
                <span>Sáng</span>
                <span class="<%= d.morningAvailable <= 0 ? 'text-error' : d.morningAvailable <= 3 ? 'text-warning' : 'text-success' %>">
                  <%= d.morningBooked %>/<%= d.morningSlots %>
                  <% if (d.morningAvailable <= 0) { %>❌<% } else if (d.morningAvailable <= 3) { %>⚠️<% } else { %>✅<% } %>
                </span>
              </div>
              <div class="w-full bg-outline rounded-full h-1">
                <div class="bg-primary rounded-full h-1 transition-all" style="width: <%= Math.min(100, (d.morningBooked / d.morningSlots) * 100) %>%"></div>
              </div>
              <div class="flex justify-between font-bold text-secondary">
                <span>Chiều</span>
                <span class="<%= d.afternoonAvailable <= 0 ? 'text-error' : d.afternoonAvailable <= 3 ? 'text-warning' : 'text-success' %>">
                  <%= d.afternoonBooked %>/<%= d.afternoonSlots %>
                  <% if (d.afternoonAvailable <= 0) { %>❌<% } else if (d.afternoonAvailable <= 3) { %>⚠️<% } else { %>✅<% } %>
                </span>
              </div>
              <div class="w-full bg-outline rounded-full h-1">
                <div class="bg-secondary rounded-full h-1 transition-all" style="width: <%= Math.min(100, (d.afternoonBooked / d.afternoonSlots) * 100) %>%"></div>
              </div>
              <div class="flex justify-between font-bold text-on-surface-variant border-t border-outline pt-0.5 mt-0.5">
                <span>Tổng</span>
                <span><%= d.bookedCount %>/<%= d.maxSlots %></span>
              </div>
            </div>
          <% } else { %>
            <div class="flex-1 flex items-center justify-center">
              <span class="text-[9px] font-black uppercase tracking-widest text-error/60">
                <%= d.isWeekend ? 'Cuối tuần' : 'Ngày nghỉ' %>
              </span>
            </div>
          <% } %>

          <%# Action button %>
          <% if (!d.isPast && !d.isWeekend) { %>
            <button onclick="openConfigModal(<%= JSON.stringify({
              date: d.date,
              maxSlots: d.maxSlots,
              morningSlots: d.morningSlots,
              afternoonSlots: d.afternoonSlots,
              isDayOff: d.isDayOff,
              note: d.note || ''
            }) %>); return false;"
                    class="mt-auto w-full text-[8px] font-black uppercase tracking-widest py-1.5 rounded-lg border border-transparent hover:border-outline hover:bg-white text-on-surface-variant hover:text-primary transition-all">
              Thiết lập
            </button>
          <% } %>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>

<%# Config Modal %>
<div id="config-modal" class="fixed inset-0 z-[100] hidden items-center justify-center px-4">
  <div class="absolute inset-0 bg-on-surface/40 backdrop-blur-sm" onclick="closeModal('config-modal')"></div>
  <div class="relative v-card w-full max-w-md !p-0 shadow-2xl animate-fade-in">
    <div class="px-6 py-4 border-b border-outline flex justify-between items-center bg-background/50">
      <h3 class="text-xl font-display font-black uppercase tracking-tight flex items-center gap-2 text-on-surface leading-none">
        <span class="material-symbols-outlined text-primary text-2xl">calendar_clock</span>
        Cài đặt slot
      </h3>
      <button onclick="closeModal('config-modal')" class="w-8 h-8 rounded-lg hover:bg-error/5 hover:text-error text-on-surface-variant flex items-center justify-center">
        <span class="material-symbols-outlined text-lg">close</span>
      </button>
    </div>
    <form method="POST" action="/admin/schedule/update" class="p-6 space-y-4">
      <% if (typeof csrfToken !== 'undefined') { %>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <% } %>

      <div>
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Ngày</label>
        <input type="date" id="config-date" name="date" readonly
               class="w-full px-4 py-3.5 bg-background border border-outline text-on-surface-variant rounded-xl cursor-not-allowed font-black text-sm">
      </div>

      <%# Slot inputs %>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Tổng slot</label>
          <input type="number" id="config-maxSlots" name="maxSlots" min="0" max="1000" required
                 class="w-full px-4 py-3 bg-white border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary font-black text-sm"
                 placeholder="VD: 50">
        </div>
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Buổi sáng</label>
          <input type="number" id="config-morningSlots" name="morningSlots" min="0" max="1000" required
                 class="w-full px-4 py-3 bg-white border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary font-black text-sm"
                 placeholder="VD: 25">
        </div>
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Buổi chiều</label>
          <input type="number" id="config-afternoonSlots" name="afternoonSlots" min="0" max="1000" required
                 class="w-full px-4 py-3 bg-white border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary font-black text-sm"
                 placeholder="VD: 25">
        </div>
      </div>

      <div class="flex items-center gap-3 px-4 py-3 rounded-xl border border-outline bg-background">
        <input type="checkbox" id="config-isDayOff" name="isDayOff" value="1"
               class="accent-error w-4 h-4">
        <label for="config-isDayOff" class="text-sm font-bold text-error uppercase tracking-widest">Đánh dấu ngày nghỉ</label>
      </div>

      <div>
        <label class="block text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2">Ghi chú <span class="text-on-surface-variant/50 font-normal">(tùy chọn)</span></label>
        <input type="text" id="config-note" name="note" maxlength="255"
               class="w-full px-4 py-3.5 bg-white border border-outline text-on-surface rounded-xl focus:outline-none focus:border-primary font-black text-sm"
               placeholder="VD: Ngày lễ 30/4, cấu hình đặc biệt...">
      </div>

      <div class="flex gap-3 pt-2">
        <button type="button" onclick="closeModal('config-modal')" class="v-btn v-btn-secondary flex-1 !py-3 !text-[10px] uppercase tracking-widest">Hủy</button>
        <button type="submit" class="v-btn v-btn-primary flex-1 !py-3 !text-[10px] uppercase tracking-widest">Lưu</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openConfigModal(config) {
    document.getElementById('config-date').value = config.date || '';
    document.getElementById('config-maxSlots').value = config.maxSlots || 0;
    document.getElementById('config-morningSlots').value = config.morningSlots || 0;
    document.getElementById('config-afternoonSlots').value = config.afternoonSlots || 0;
    document.getElementById('config-note').value = config.note || '';
    document.getElementById('config-isDayOff').checked = !!config.isDayOff;
    const modal = document.getElementById('config-modal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
  function closeModal(id) {
    const modal = document.getElementById(id);
    modal.classList.add('hidden');
    modal.classList.remove('flex');
  }
  // Close modal on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal('config-modal');
  });
</script>
