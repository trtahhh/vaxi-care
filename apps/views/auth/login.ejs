<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - VaxiCare</title>
    <link rel="stylesheet" href="/static/client/auth.css">
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-logo">
                <span class="logo-text">VaxiCare</span>
                <p class="logo-sub">Hệ thống quản lý tiêm chủng</p>
            </div>
            <h2 class="auth-title">Đăng nhập</h2>
            
            <form action="/auth/login" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email">Email <span class="required">*</span></label>
                    <input id="email" name="email" type="email" placeholder="Nhập email của bạn" required />
                </div>
                
                <div class="form-group">
                    <label for="password">Mật khẩu <span class="required">*</span></label>
                    <input id="password" name="password" type="password" placeholder="Nhập mật khẩu" required />
                </div>
                
                <% if (error) { %>
                    <p class="auth-error"><%= error %></p>
                <% } %>
                
                <% if (success) { %>
                    <p class="auth-success"><%= success %></p>
                <% } %>

                <div class="auth-forgot">
                    <a href="/auth/forgot-password">Quên mật khẩu?</a>
                </div>
                
                <button type="submit" class="auth-btn">Đăng nhập</button>
            </form>
            
            <p class="auth-switch">
                Chưa có tài khoản? <a href="/auth/register">Đăng ký ngay</a>
            </p>
        </div>
    </div>
</body>
</html>
