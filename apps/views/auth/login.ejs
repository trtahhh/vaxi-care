<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập - VaxiCare</title>
    <link rel="stylesheet" href="/css/tailwind-compiled.css?v=2">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght@400;700&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-background min-h-screen flex items-center justify-center p-6 sm:p-12 overflow-x-hidden">

    <div class="w-full max-w-md animate-fade-in">
        <!-- Brand Identity -->
        <div class="flex flex-col items-center mb-12">
            <div class="w-20 h-20 rounded-[1.5rem] bg-primary flex items-center justify-center text-white mb-6 shadow-2xl shadow-primary/30 border-b-[6px] border-black/10">
                <span class="material-symbols-outlined text-5xl">child_care</span>
            </div>
            <h1 class="text-4xl v-title tracking-tight text-on-surface uppercase">VaxiCare</h1>
            <div class="h-1.5 w-12 bg-primary mt-3 rounded-full"></div>
            <p class="text-on-surface-variant text-[10px] font-black uppercase tracking-[0.4em] mt-4 opacity-70 text-center">Hệ thống Y tế Đạt chuẩn ISO</p>
        </div>

        <!-- Main Card -->
        <div class="v-card !p-10 md:!p-12 border-2 border-outline relative overflow-hidden group">
            <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>
            
            <div class="mb-10">
                <h2 class="text-3xl v-title uppercase tracking-tighter text-on-surface">Đăng nhập</h2>
                <p class="text-on-surface-variant text-sm font-medium mt-1">Truy cập vào sổ tiêm chủng của bạn</p>
            </div>
            
            <form action="/auth/login" method="POST" class="space-y-8">
                <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <!-- Credentials Section -->
                <div class="space-y-5">
                    <div class="group">
                        <label for="email" class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 block ml-1">Địa chỉ Email</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">alternate_email</span>
                            <input id="email" name="email" type="email" placeholder="EMAIL@EXAMPLE.COM" required
                                   class="w-full pl-12 pr-4 py-4 bg-background border-2 border-outline text-on-surface rounded-2xl focus:outline-none focus:border-primary transition-all font-black text-xs uppercase tracking-tight placeholder:opacity-30">
                        </div>
                    </div>
                    
                    <div class="group">
                        <label for="password" class="text-[10px] font-black uppercase tracking-widest text-on-surface-variant mb-2 block ml-1">Mật khẩu bảo mật</label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant group-focus-within:text-primary transition-colors text-xl">lock_open</span>
                            <input id="password" name="password" type="password" placeholder="••••••••" required
                                   class="w-full pl-12 pr-4 py-4 bg-background border-2 border-outline text-on-surface rounded-2xl focus:outline-none focus:border-primary transition-all font-black text-xs uppercase tracking-tight placeholder:opacity-30">
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end">
                    <a href="#" class="text-[10px] font-black text-primary hover:text-on-surface uppercase tracking-widest transition-colors">Quên mật khẩu?</a>
                </div>
                
                <!-- Feedback Alerts -->
                <% if (error) { %>
                    <div class="p-4 rounded-xl bg-error text-white border-transparent flex items-center gap-4 shadow-lg shadow-error/20 animate-shake">
                        <span class="material-symbols-outlined text-2xl">report</span>
                        <p class="text-[11px] font-black uppercase tracking-widest leading-tight"><%= error %></p>
                    </div>
                <% } %>
                
                <% if (success) { %>
                    <div class="p-4 rounded-xl bg-secondary text-white border-transparent flex items-center gap-4 shadow-lg shadow-secondary/20">
                        <span class="material-symbols-outlined text-2xl">check_circle</span>
                        <p class="text-[11px] font-black uppercase tracking-widest leading-tight"><%= success %></p>
                    </div>
                <% } %>

                <button type="submit" class="v-btn v-btn-primary w-full !py-5 !rounded-2xl shadow-xl shadow-primary/30 hover:shadow-primary/40 uppercase !text-sm tracking-[0.2em] transition-all transform hover:-translate-y-1 active:scale-95">
                    Xác nhận Đăng nhập
                </button>
            </form>
            
            <div class="mt-12 pt-8 border-t-2 border-outline text-center">
                <p class="text-on-surface-variant text-[11px] font-bold uppercase tracking-widest">
                    Chưa có tài khoản? 
                    <a href="/auth/register" class="font-black text-primary hover:text-on-surface ml-2 underline decoration-2 underline-offset-4 transition-all uppercase">Đăng ký ngay</a>
                </p>
            </div>
        </div>

        <p class="text-center text-[9px] text-on-surface-variant font-black uppercase tracking-[0.4em] mt-12 opacity-30">
            &copy; 2026 VaxiCare • Professional Health Network
        </p>
    </div>
</body>
</html>
