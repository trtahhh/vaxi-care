{
  "name": "vaxi-care-backend",
  "version": "1.0.0",
  "description": "Backend for VaxiCare",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run watch:css\" \"nodemon app.js\"",
    "build:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind-compiled.css --minify",
    "watch:css": "npx tailwindcss -i ./public/css/input.css -o ./public/css/tailwind-compiled.css --watch",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPatterns=test/unittest",
    "test:integration": "jest --testPathPatterns=test/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.7",
    "ejs": "^5.0.1",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.8",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19"
  }
}
